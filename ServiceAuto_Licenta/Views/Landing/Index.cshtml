
@{
    ViewData["Title"] = "AutoService Pro";
    Layout = null; // pagina separata fara layout-ul cu sidebar
}
<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AutoService Pro — Management System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #0f172a;
            color: #f1f5f9;
            min-height: 100vh;
        }

        /* ── Navbar ── */
        .landing-nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 100;
            padding: 16px 48px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
        }

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .nav-logo-icon {
            width: 36px;
            height: 36px;
            background: #2563eb;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .nav-logo-text strong {
            color: #f1f5f9;
            font-size: 16px;
            display: block;
            line-height: 1.2;
        }

        .nav-logo-text span {
            color: #2563eb;
            font-size: 12px;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-nav-login {
            padding: 8px 20px;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 8px;
            color: #f1f5f9;
            background: transparent;
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.15s;
        }

            .btn-nav-login:hover {
                background: rgba(255,255,255,0.08);
                color: #f1f5f9;
            }

        .btn-nav-register {
            padding: 8px 20px;
            border: none;
            border-radius: 8px;
            color: white;
            background: #2563eb;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.15s;
        }

            .btn-nav-register:hover {
                background: #1d4ed8;
                color: white;
            }

        /* ── Hero ── */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            overflow: hidden;
            padding: 120px 48px 80px;
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 50%, rgba(37,99,235,0.15) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(124,58,237,0.1) 0%, transparent 50%), radial-gradient(ellipse at 60% 80%, rgba(16,163,74,0.08) 0%, transparent 40%);
        }

        .hero-grid {
            position: absolute;
            inset: 0;
            background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 60px 60px;
        }

        .hero-content {
            position: relative;
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 420px;
            gap: 80px;
            align-items: center;
        }

        .hero-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(37,99,235,0.15);
            border: 1px solid rgba(37,99,235,0.3);
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 13px;
            color: #93c5fd;
            margin-bottom: 24px;
        }

        .hero-title {
            font-size: 56px;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 20px;
            letter-spacing: -0.02em;
        }

            .hero-title span {
                color: #2563eb;
            }

        .hero-subtitle {
            font-size: 18px;
            color: #94a3b8;
            line-height: 1.7;
            margin-bottom: 40px;
            max-width: 500px;
        }

        .hero-stats {
            display: flex;
            gap: 32px;
            margin-bottom: 40px;
        }

        .hero-stat {
            text-align: center;
        }

            .hero-stat strong {
                display: block;
                font-size: 28px;
                font-weight: 700;
                color: #f1f5f9;
            }

            .hero-stat span {
                font-size: 13px;
                color: #64748b;
            }

        .hero-cta {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .btn-hero-primary {
            padding: 14px 28px;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: background 0.15s, transform 0.15s;
        }

            .btn-hero-primary:hover {
                background: #1d4ed8;
                color: white;
                transform: translateY(-1px);
            }

        .btn-hero-secondary {
            padding: 14px 28px;
            background: transparent;
            color: #f1f5f9;
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 10px;
            font-size: 15px;
            cursor: pointer;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.15s;
        }

            .btn-hero-secondary:hover {
                background: rgba(255,255,255,0.06);
                color: #f1f5f9;
            }

        /* ── Card autentificare ── */
        .auth-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            border-radius: 20px;
            padding: 32px;
            backdrop-filter: blur(20px);
        }

        .auth-tabs {
            display: flex;
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
            padding: 4px;
            margin-bottom: 28px;
        }

        .auth-tab {
            flex: 1;
            padding: 9px;
            border: none;
            border-radius: 8px;
            background: transparent;
            color: #64748b;
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

            .auth-tab.active {
                background: #2563eb;
                color: white;
            }

        .auth-form {
            display: none;
        }

            .auth-form.active {
                display: block;
            }

        .form-group {
            margin-bottom: 16px;
        }

        .form-label-auth {
            display: block;
            font-size: 13px;
            font-weight: 500;
            color: #94a3b8;
            margin-bottom: 6px;
        }

        .form-input {
            width: 100%;
            padding: 11px 14px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 9px;
            color: #f1f5f9;
            font-size: 14px;
            outline: none;
            transition: border-color 0.15s;
        }

            .form-input:focus {
                border-color: #2563eb;
                background: rgba(37,99,235,0.08);
            }

            .form-input::placeholder {
                color: #475569;
            }

        .form-input-icon {
            position: relative;
        }

            .form-input-icon i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #475569;
                font-size: 15px;
            }

            .form-input-icon input {
                padding-left: 38px;
            }

        .btn-submit {
            width: 100%;
            padding: 12px;
            background: #2563eb;
            color: white;
            border: none;
            border-radius: 9px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.15s;
            margin-top: 8px;
        }

            .btn-submit:hover {
                background: #1d4ed8;
            }

        .auth-divider {
            text-align: center;
            color: #475569;
            font-size: 12px;
            margin: 16px 0;
            position: relative;
        }

            .auth-divider::before, .auth-divider::after {
                content: '';
                position: absolute;
                top: 50%;
                width: 40%;
                height: 1px;
                background: rgba(255,255,255,0.08);
            }

            .auth-divider::before {
                left: 0;
            }

            .auth-divider::after {
                right: 0;
            }

        .error-msg {
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.25);
            border-radius: 8px;
            padding: 10px 14px;
            font-size: 13px;
            color: #fca5a5;
            margin-bottom: 16px;
        }

        /* ── Features ── */
        .features {
            padding: 100px 48px;
            max-width: 1200px;
            margin: 0 auto;
        }

        .section-label {
            display: inline-block;
            background: rgba(37,99,235,0.15);
            border: 1px solid rgba(37,99,235,0.3);
            border-radius: 20px;
            padding: 5px 14px;
            font-size: 12px;
            color: #93c5fd;
            margin-bottom: 16px;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .section-title {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 12px;
        }

        .section-subtitle {
            font-size: 16px;
            color: #64748b;
            margin-bottom: 56px;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
        }

        .feature-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 16px;
            padding: 28px;
            transition: all 0.2s;
        }

            .feature-card:hover {
                background: rgba(255,255,255,0.06);
                border-color: rgba(37,99,235,0.3);
                transform: translateY(-3px);
            }

        .feature-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            margin-bottom: 16px;
        }

        .feature-card h4 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #f1f5f9;
        }

        .feature-card p {
            font-size: 14px;
            color: #64748b;
            line-height: 1.6;
        }

        /* ── Footer ── */
        .landing-footer {
            border-top: 1px solid rgba(255,255,255,0.06);
            padding: 32px 48px;
            text-align: center;
            color: #475569;
            font-size: 13px;
        }

        /* ── Responsive ── */
        @@media (max-width: 900px) {
            .hero-content {
                grid-template-columns: 1fr;
            }

            .hero {
                padding: 120px 24px 60px;
            }

            .hero-title {
                font-size: 36px;
            }

            .features {
                padding: 60px 24px;
            }

            .features-grid {
                grid-template-columns: 1fr;
            }

            .landing-nav {
                padding: 16px 24px;
            }
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="landing-nav">
        <a class="nav-logo" href="#">
            <div class="nav-logo-icon">
                <i class="bi bi-wrench-adjustable" style="color:white;"></i>
            </div>
            <div class="nav-logo-text">
                <strong>AutoService</strong>
                <span>Management Pro</span>
            </div>
        </a>
        <div class="nav-links">
            <a href="#features" class="btn-nav-login">Funcționalități</a>
            <a href="#auth" class="btn-nav-login" onclick="switchTab('login')">Login</a>
            <a href="#auth" class="btn-nav-register" onclick="switchTab('register')">Creează cont</a>
        </div>
    </nav>

    <!-- Hero -->
    <section class="hero" id="auth">
        <div class="hero-bg"></div>
        <div class="hero-grid"></div>

        <div class="hero-content">
            <!-- Text stanga -->
            <div>
                <div class="hero-badge">
                    <i class="bi bi-stars"></i>
                    Sistem complet de gestiune service auto
                </div>

                <h1 class="hero-title">
                    Gestionează<br>
                    service-ul tău<br>
                    <span>profesional</span>
                </h1>

                <p class="hero-subtitle">
                    Platformă modernă pentru gestiunea clienților, vehiculelor,
                    programărilor, pieselor și facturilor — totul într-un singur loc.
                </p>

                <div class="hero-stats">
                    <div class="hero-stat">
                        <strong>100%</strong>
                        <span>Funcțional</span>
                    </div>
                    <div class="hero-stat">
                        <strong>7+</strong>
                        <span>Module</span>
                    </div>
                    <div class="hero-stat">
                        <strong>Real-time</strong>
                        <span>Statistici</span>
                    </div>
                </div>

                <div class="hero-cta">
                    <a href="#auth" class="btn-hero-primary" onclick="switchTab('register')">
                        <i class="bi bi-rocket-takeoff"></i>
                        Începe gratuit
                    </a>
                    <a href="#features" class="btn-hero-secondary">
                        <i class="bi bi-play-circle"></i>
                        Află mai multe
                    </a>
                </div>
            </div>

            <!-- Card autentificare dreapta -->
            <div class="auth-card">
                @if (TempData["LoginError"] != null)
                {
                    <div class="error-msg">
                        <i class="bi bi-exclamation-circle me-2"></i>@TempData["LoginError"]
                    </div>
                }
                @if (TempData["RegisterError"] != null)
                {
                    <div class="error-msg">
                        <i class="bi bi-exclamation-circle me-2"></i>@TempData["RegisterError"]
                    </div>
                }

                <!-- Tabs -->
                <div class="auth-tabs">
                    <button class="auth-tab active" id="tab-login" onclick="switchTab('login')">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Autentificare
                    </button>
                    <button class="auth-tab" id="tab-register" onclick="switchTab('register')">
                        <i class="bi bi-person-plus me-1"></i> Cont nou
                    </button>
                </div>

                <!-- Formular Login -->
                <div class="auth-form active" id="form-login">
                    <form asp-controller="Landing" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label class="form-label-auth">Email</label>
                            <div class="form-input-icon">
                                <i class="bi bi-envelope"></i>
                                <input type="email" name="email" class="form-input"
                                       placeholder="adresa@email.ro" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label-auth">Parolă</label>
                            <div class="form-input-icon">
                                <i class="bi bi-lock"></i>
                                <input type="password" name="password" class="form-input"
                                       placeholder="••••••••" required />
                            </div>
                        </div>
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
                            <label style="display:flex;align-items:center;gap:6px;font-size:13px;color:#94a3b8;cursor:pointer;">
                                <input type="checkbox" name="rememberMe" style="accent-color:#2563eb;" />
                                Ține-mă minte
                            </label>
                        </div>
                        <button type="submit" class="btn-submit">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Intră în cont
                        </button>
                    </form>

                    <div class="auth-divider">sau</div>

                    <div style="text-align:center;font-size:13px;color:#64748b;">
                        Nu ai cont?
                        <a href="#" onclick="switchTab('register')" style="color:#2563eb;text-decoration:none;font-weight:500;">
                            Creează unul acum
                        </a>
                    </div>
                </div>

                <!-- Formular Register -->
                <div class="auth-form" id="form-register">
                    <form asp-controller="Landing" asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div class="form-group">
                            <label class="form-label-auth">Nume complet</label>
                            <div class="form-input-icon">
                                <i class="bi bi-person"></i>
                                <input type="text" name="nume" class="form-input"
                                       placeholder="Ion Popescu" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label-auth">Email</label>
                            <div class="form-input-icon">
                                <i class="bi bi-envelope"></i>
                                <input type="email" name="email" class="form-input"
                                       placeholder="adresa@email.ro" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label-auth">Parolă</label>
                            <div class="form-input-icon">
                                <i class="bi bi-lock"></i>
                                <input type="password" name="password" class="form-input"
                                       placeholder="Minim 6 caractere" required />
                            </div>
                        </div>
                        <div class="form-group">
                            <label class="form-label-auth">Confirmare parolă</label>
                            <div class="form-input-icon">
                                <i class="bi bi-lock-fill"></i>
                                <input type="password" name="confirmPassword" class="form-input"
                                       placeholder="Repeta parola" required />
                            </div>
                        </div>
                        <button type="submit" class="btn-submit">
                            <i class="bi bi-person-plus me-2"></i>Creează contul
                        </button>
                    </form>

                    <div class="auth-divider">sau</div>

                    <div style="text-align:center;font-size:13px;color:#64748b;">
                        Ai deja cont?
                        <a href="#" onclick="switchTab('login')" style="color:#2563eb;text-decoration:none;font-weight:500;">
                            Autentifică-te
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Features -->
    <section class="features" id="features">
        <div style="text-align:center;margin-bottom:56px;">
            <div class="section-label">Functionalitati</div>
            <h2 class="section-title">Tot ce ai nevoie pentru service-ul tău</h2>
            <p class="section-subtitle">O platformă completă care simplifică toate procesele operaționale</p>
        </div>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon" style="background:rgba(37,99,235,0.15);">
                    <i class="bi bi-people-fill" style="color:#2563eb;"></i>
                </div>
                <h4>Gestiune Clienți</h4>
                <p>Bază de date completă cu clienții service-ului, date de contact și istoricul vizitelor.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background:rgba(22,163,74,0.15);">
                    <i class="bi bi-car-front-fill" style="color:#16a34a;"></i>
                </div>
                <h4>Gestiune Vehicule</h4>
                <p>Înregistrarea vehiculelor cu marcă, model, VIN, număr de înmatriculare și kilometraj.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background:rgba(124,58,237,0.15);">
                    <i class="bi bi-calendar-check-fill" style="color:#7c3aed;"></i>
                </div>
                <h4>Programări Service</h4>
                <p>Creare și urmărire programări cu statusuri în timp real: programat, în lucru, finalizat.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background:rgba(234,88,12,0.15);">
                    <i class="bi bi-gear-fill" style="color:#ea580c;"></i>
                </div>
                <h4>Inventar Piese</h4>
                <p>Gestiunea stocurilor de piese cu alerte automate pentru reaprovizionare și istoric utilizare.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background:rgba(16,163,74,0.15);">
                    <i class="bi bi-receipt-cutoff" style="color:#16a34a;"></i>
                </div>
                <h4>Facturare Automată</h4>
                <p>Generare facturi cu calcul automat TVA 19%, plată cu card simulată și evidența încasărilor.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon" style="background:rgba(37,99,235,0.15);">
                    <i class="bi bi-bar-chart-fill" style="color:#2563eb;"></i>
                </div>
                <h4>Rapoarte & Statistici</h4>
                <p>Dashboard cu grafice interactive, top clienți, lucrări frecvente și integrare Power BI.</p>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="landing-footer">
        <p>© 2024 AutoService Management Pro — Lucrare de licenta Informatica Economica</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        function switchTab(tab) {
            document.getElementById('form-login').classList.remove('active');
            document.getElementById('form-register').classList.remove('active');
            document.getElementById('tab-login').classList.remove('active');
            document.getElementById('tab-register').classList.remove('active');

            document.getElementById('form-' + tab).classList.add('active');
            document.getElementById('tab-' + tab).classList.add('active');

            document.getElementById('auth').scrollIntoView({ behavior: 'smooth' });
        }

        // Daca exista eroare de register, deschide tab-ul register automat
        @if (TempData["ShowRegister"] != null)
        {
                <text>
                window.addEventListener('DOMContentLoaded', () => switchTab('register'));
                </text>
        }
    </script>

</body>
</html>
