@model ServiceAutoLicenta.Models.Entities.Piesa
@{
    ViewData["Title"]="Șterge piesă";
}

<div class="page-header">
    <div style="display:flex;align-items:center;gap:12px;">
        <a asp-action="Index" class="btn-outline-custom" style="padding:8px 12px;">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2>Șterge piesă</h2>
            <p>Această acțiune este ireversibilă</p>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="form-card" style="border:1px solid #fca5a5;">
            <div style="text-align:center;margin-bottom:24px;">
                <div style="width:56px;height:56px;background:rgba(220,38,38,0.25);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 12px;">
                    <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;font-size:22px;"></i>
                </div>
                <h5 style="font-weight:600;">Confirmi ștergerea?</h5>
                <p style="color:var(--text-muted);font-size:14px;">
                    Piesa <strong>@Model.Denumire</strong> va fi ștearsă permanent.
                </p>
            </div>

            @if(Model.LucrarePiese.Any())
            {
                <div class="alert-warning-custom mb-4">
                    <i class="bi bi-info-circle-fill"></i>
                    Piesa a fost utilizată în <strong>@Model.LucrarePiese.Count lucrări</strong> și nu poate fi ștearsă.
                </div>
            }

            <div style="background:rgba(0,0,0,0.2);border-radius:10px;padding:16px;margin-bottom:24px;">
                <div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:8px;">
                    <span style="color:var(--text-muted);">Cod</span>
                    <span style="font-family:monospace;font-weight:600;">@Model.CodPiesa</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:8px;">
                    <span style="color:var(--text-muted);">Denumire</span>
                    <span>@Model.Denumire</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Stoc curent</span>
                    <span>@Model.StocCurent buc.</span>
                </div>
            </div>

            <form asp-action="Sterge" method="post">
                <input type="hidden" asp-for="Id" />
                <div style="display:flex;gap:12px;">
                    <button type="submit"
                            style="flex:1;background:#ef4444;color:white;border:none;padding:10px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;"
                            @(Model.LucrarePiese.Any()?"disabled":"")>
                        <i class="bi bi-trash me-1"></i> Șterge definitiv
                    </button>
                    <a asp-action="Index" class="btn-outline-custom" style="flex:1;justify-content:center;">
                        Anulează
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
