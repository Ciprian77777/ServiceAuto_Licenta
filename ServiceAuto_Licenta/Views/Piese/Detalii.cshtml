@model ServiceAutoLicenta.Models.Entities.Piesa
@{
    ViewData["Title"]="Detalii piesă";
}

<div class="page-header">
    <div style="display:flex;align-items:center;gap:12px;">
        <a asp-action="Index" class="btn-outline-custom" style="padding:8px 12px;">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2>@Model.Denumire</h2>
            <p style="font-family:monospace;">@Model.CodPiesa</p>
        </div>
    </div>
    <a asp-action="Editeaza" asp-route-id="@Model.Id" class="btn-outline-custom">
        <i class="bi bi-pencil"></i> Editează
    </a>
</div>

@if(TempData["Succes"]!=null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="content-card mb-4">
            <div class="content-card-header"><h5>Date piesă</h5></div>
            <div style="padding:20px;display:flex;flex-direction:column;gap:12px;">
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Cod</span>
                    <span style="font-family:monospace;font-weight:600;background:rgba(255,255,255,0.12);padding:2px 8px;border-radius:4px;">@Model.CodPiesa</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Producător</span>
                    <span>@(Model.Producator??"-")</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Preț achiziție</span>
                    <span>@Model.PretAchizitie.ToString("N2") lei</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Preț vânzare</span>
                    <strong>@Model.PretVanzare.ToString("N2") lei</strong>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;padding-top:8px;border-top:1px solid var(--border-color);">
                    <span style="color:var(--text-muted);">Adaos comercial</span>
                    <span style="color:#16a34a;font-weight:600;">@((Model.PretVanzare - Model.PretAchizitie).ToString("N2")) lei</span>
                </div>
            </div>
        </div>

        <div class="content-card" style="border:1.5px solid @(Model.StocScazut? "#fca5a5" : "#86efac");">
            <div class="content-card-header" style="background:@(Model.StocScazut? "#fef2f2" : "#f0fdf4");">
                <h5 style="color:@(Model.StocScazut? "#dc2626" : "#16a34a");">
                    <i class="bi bi-box-seam me-2"></i>Stoc
                </h5>
            </div>
            <div style="padding:20px;text-align:center;">
                <div style="font-size:48px;font-weight:700;color:@(Model.StocScazut? "#ef4444" : "#16a34a");">
                    @Model.StocCurent
                </div>
                <div style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">
                    bucăți disponibile (min. @Model.StocMinim)
                </div>
                @{
                    int proc=Model.StocMinim > 0? Math.Min(100, (int)((double)Model.StocCurent / Model.StocMinim * 100)) : 100;
                }
                <div style="background:#e2e8f0;border-radius:4px;height:8px;margin-bottom:20px;">
                    <div style="width:@(Math.Min(proc, 100))%;height:100%;border-radius:4px;background:@(Model.StocScazut? "#ef4444" : "#16a34a");"></div>
                </div>
                <form asp-action="ActualizeazaStoc" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div style="display:flex;gap:8px;">
                        <input type="number" name="cantitate"
                               style="flex:1;padding:8px 12px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;outline:none;"
                               placeholder="ex: +10 sau -5" />
                        <button type="submit" class="btn-outline-custom">
                            <i class="bi bi-arrow-repeat"></i>
                        </button>
                    </div>
                    <small style="font-size:11px;color:var(--text-muted);margin-top:4px;display:block;">
                        Pozitiv=intrare stoc, negativ=ieșire stoc
                    </small>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Istoric utilizare</h5>
                    <p>@Model.LucrarePiese.Count utilizări înregistrate</p>
                </div>
            </div>
            @if(!Model.LucrarePiese.Any())
            {
                <div style="text-align:center;padding:40px;color:var(--text-muted);">
                    <i class="bi bi-clock-history" style="font-size:2.5rem;opacity:0.3;"></i>
                    <p style="margin-top:10px;">Piesa nu a fost utilizată în nicio lucrare.</p>
                </div>
            }
            else
            {
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Data</th>
                            <th>Mașină</th>
                            <th>Client</th>
                            <th>Cant.</th>
                            <th>Preț unit.</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var lp in Model.LucrarePiese.OrderByDescending(x=>x.Lucrare.Programare.DataIntrare))
                        {
                            <tr>
                                <td style="font-size:13px;">@lp.Lucrare.Programare.DataIntrare.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <span style="font-family:monospace;background:rgba(255,255,255,0.12);padding:2px 8px;border-radius:4px;font-size:12px;">
                                        @lp.Lucrare.Programare.Masina.NrInmatriculare
                                    </span>
                                </td>
                                <td style="font-size:13px;">@lp.Lucrare.Programare.Masina.Client.NumeComplet</td>
                                <td style="font-size:13px;">@lp.Cantitate buc.</td>
                                <td style="font-size:13px;color:var(--text-muted);">@lp.PretUnitar.ToString("N2") lei</td>
                                <td style="font-weight:600;font-size:13px;">@lp.Subtotal.ToString("N2") lei</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>