@model IEnumerable<ServiceAutoLicenta.Models.Entities.Piesa>
@{
    ViewData["Title"]="Piese de schimb";
}

<div class="page-header">
    <div>
        <h2>Piese de schimb</h2>
        <p>Gestionează stocurile de piese de schimb</p>
    </div>
    <a asp-action="Adauga" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Piesă nouă
    </a>
</div>

@if(TempData["Succes"]!=null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if(TempData["Eroare"]!=null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Eroare"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-with-stats">
    <aside class="pstats">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-gear-fill"></i></div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Total Piese</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
            <div class="stat-value">@(ViewBag.NrAlerte??0)</div>
            <div class="stat-label">Stoc scăzut</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
            <div class="stat-value">@Model.Count(p=>p.StocCurent==0)</div>
            <div class="stat-label">Stoc epuizat</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="stat-value" style="font-size:22px;">@Model.Sum(p=>p.StocCurent * p.PretAchizitie).ToString("N0")</div>
            <div class="stat-label">Valoare stoc (lei)</div>
        </div>
    </aside>

    <div class="pmain">
        @if((ViewBag.NrAlerte??0) > 0 && ViewBag.StocScazut!=true)
        {
            <div class="alert-warning-custom mb-3">
                <i class="bi bi-exclamation-triangle-fill" style="color:#d97706;font-size:16px;"></i>
                <span><strong>@ViewBag.NrAlerte piese</strong> au stocul scăzut și necesită reaprovizionare.</span>
                <a asp-action="Index" asp-route-stocScazut="true"
                   style="margin-left:auto;background:#f59e0b;color:white;padding:4px 12px;font-size:12px;text-decoration:none;font-weight:600;">
                    Arată
                </a>
            </div>
        }

        <div class="content-card" style="margin-bottom:12px;">
            <div style="padding:12px 18px;">
                <form method="get" style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                    <div style="position:relative;flex:1;min-width:200px;">
                        <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#aaa;font-size:13px;"></i>
                        <input type="text" name="cautare" value="@ViewBag.Cautare" class="form-control"
                               style="padding-left:32px;" placeholder="Caută după denumire, cod, producător..." />
                    </div>
                    <select name="filtru" class="form-select" style="width:auto;">
                        <option value="">Toate</option>
                        <option value="stocScazut" selected="@(ViewBag.StocScazut==true)">Stoc scăzut</option>
                        <option value="disponibil">Disponibil</option>
                    </select>
                    <button type="submit" class="btn-outline-custom"><i class="bi bi-funnel me-1"></i>Filtrează</button>
                    @if(!string.IsNullOrEmpty(ViewBag.Cautare)||ViewBag.StocScazut==true)
                    {
                        <a asp-action="Index" class="btn-outline-custom" style="color:#b91c1c;border-color:#fca5a5;"><i class="bi bi-x-lg"></i></a>
                    }
                </form>
            </div>
        </div>

        <div class="content-card">
            @if(!Model.Any())
            {
                <div style="text-align:center;padding:50px 20px;color:#aaa;">
                    <i class="bi bi-gear" style="font-size:2.5rem;opacity:0.3;"></i>
                    <p style="margin-top:12px;">Nu există piese înregistrate.</p>
                    <a asp-action="Adauga" class="btn-primary-custom" style="margin-top:8px;">
                        <i class="bi bi-plus-lg"></i> Adaugă prima piesă
                    </a>
                </div>
            }
            else
            {
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Piesă / Cod</th>
                            <th>Stoc</th>
                            <th>Preț vânzare</th>
                            <th>Producător</th>
                            <th>Status</th>
                            <th>Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var piesa in Model)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600;font-size:13px;">@piesa.Denumire</div>
                                    <div style="font-size:11px;color:#aaa;font-family:monospace;">@piesa.CodPiesa</div>
                                </td>
                                <td>
                                    @{
                                        int procent=piesa.StocMinim>0?Math.Min(100,(int)((double)piesa.StocCurent/piesa.StocMinim*100)):100;
                                        string culoare=piesa.StocCurent==0?"#b91c1c":piesa.StocScazut?"#f59e0b":"#15803d";
                                    }
                                    <div style="display:flex;align-items:center;gap:7px;">
                                        <div class="stock-bar">
                                            <div class="stock-bar-fill" style="width:@(Math.Min(procent,100))%;background:@culoare;"></div>
                                        </div>
                                        <span style="font-size:12px;font-weight:500;">@piesa.StocCurent / @piesa.StocMinim</span>
                                    </div>
                                </td>
                                <td style="font-size:13px;font-weight:600;">@piesa.PretVanzare.ToString("N2") lei</td>
                                <td style="font-size:12px;color:#888;">@(piesa.Producator??"-")</td>
                                <td>
                                    @if(piesa.StocCurent==0)
                                    {
                                        <span class="badge-status badge-neplata">Epuizat</span>
                                    }
                                    else if(piesa.StocScazut)
                                    {
                                        <span class="badge-status badge-partial">Stoc scăzut</span>
                                    }
                                    else
                                    {
                                        <span class="badge-status badge-platita">În stoc</span>
                                    }
                                </td>
                                <td>
                                    <div style="display:flex;gap:5px;">
                                        <a asp-action="Detalii" asp-route-id="@piesa.Id" class="btn-outline-custom" style="padding:4px 9px;"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Editeaza" asp-route-id="@piesa.Id" class="btn-outline-custom" style="padding:4px 9px;"><i class="bi bi-pencil"></i></a>
                                        <a asp-action="Sterge" asp-route-id="@piesa.Id" class="btn-outline-custom" style="padding:4px 9px;color:#b91c1c;border-color:#fca5a5;"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
