@using ServiceAutoLicenta.Models.Entities
@{
    ViewData["Title"]="Dashboard";
    decimal venLuna=ViewBag.VenituriLuna;
    decimal venAnt=ViewBag.VenituriLunaAnt;
    decimal diff=venAnt>0?Math.Round((venLuna-venAnt)/venAnt*100,1):0;
}

<div class="page-header">
    <div class="page-header-left">
        <h2>Dashboard</h2>
        <p>@DateTime.Today.ToString("dd MMMM yyyy")</p>
    </div>
    <a asp-controller="Programari" asp-action="Adauga" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Programare nouă
    </a>
</div>

<div style="background:#111;border-top:3px solid #c1272d;padding:18px 24px;margin-bottom:20px;display:flex;align-items:center;justify-content:space-between;">
    <div>
        <div style="font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#666;margin-bottom:4px;">Venituri luna curentă</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:38px;font-weight:700;color:#fff;line-height:1;">
            @venLuna.ToString("N0") <span style="font-size:18px;color:#888;">lei</span>
        </div>
    </div>
    @if(diff!=0)
    {
    <div style="text-align:right;">
        <div style="font-size:11px;color:#666;margin-bottom:4px;">față de luna trecută</div>
        <div style="font-family:'Barlow Condensed',sans-serif;font-size:28px;font-weight:700;color:@(diff>=0?"#16a34a":"#c1272d");">
            @(diff>=0?"+":"")@diff%
        </div>
    </div>
    }
</div>

@if(ViewBag.AlerteStoc > 0)
{
<div class="content-card mb-3">
    <div class="content-card-header" style="background:#fffbeb;border-bottom-color:#fde68a;">
        <div style="display:flex;align-items:center;gap:8px;">
            <i class="bi bi-exclamation-triangle-fill" style="color:#f59e0b;"></i>
            <h5 style="color:#92400e;">@ViewBag.AlerteStoc piese cu stoc scăzut</h5>
        </div>
        <a asp-controller="Piese" asp-action="Index" asp-route-stocScazut="true" class="btn-outline-custom" style="padding:4px 10px;font-size:10px;">
            Gestionează <i class="bi bi-arrow-right"></i>
        </a>
    </div>
    <table class="custom-table">
        <thead><tr><th>Piesă</th><th>Cod</th><th>Stoc</th><th>Minim</th><th></th></tr></thead>
        <tbody>
        @foreach(var p in ViewBag.PieseStocScazut)
        {
            <tr>
                <td style="font-weight:600;">@p.Denumire</td>
                <td style="font-size:11px;color:#999;">@p.CodPiesa</td>
                <td><span class="badge-status badge-neplata">@p.StocCurent buc.</span></td>
                <td style="color:#aaa;font-size:12px;">@p.StocMinim buc.</td>
                <td>
                    <a asp-controller="Piese" asp-action="Detalii" asp-route-id="@p.Id" class="btn-outline-custom" style="padding:3px 9px;font-size:10px;">
                        <i class="bi bi-box-seam"></i>
                    </a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
}

<div class="row g-3 mb-3">
    <div class="col-lg-7">
        <div class="content-card">
            <div class="content-card-header">
                <h5>Ultimele programări</h5>
                <a asp-controller="Programari" asp-action="Index" class="btn-outline-custom" style="padding:4px 10px;font-size:10px;">
                    Toate <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <table class="custom-table">
                <thead>
                    <tr><th>Client / Mașină</th><th>Data</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                @if(ViewBag.UltimeProgramari!=null)
                {
                    @foreach(var p in ViewBag.UltimeProgramari)
                    {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:9px;">
                                <div class="client-avatar">@(p.Masina.Client.Nume[0])@(p.Masina.Client.Prenume[0])</div>
                                <div>
                                    <div style="font-weight:600;font-size:13px;">@p.Masina.Client.NumeComplet</div>
                                    <div style="font-size:11px;color:#aaa;">@p.Masina.NrInmatriculare — @p.Masina.Marca @p.Masina.ModelMasina</div>
                                </div>
                            </div>
                        </td>
                        <td style="font-size:12px;color:#888;">@p.DataIntrare.ToString("dd.MM.yy")</td>
                        <td>
                            <span class="badge-status @(p.Status==StatusProgramare.Finalizata?"badge-finalizata":p.Status==StatusProgramare.InLucru?"badge-inlucru":p.Status==StatusProgramare.Anulata?"badge-anulata":"badge-scheduled")">@p.Status</span>
                        </td>
                        <td>
                            <a asp-controller="Programari" asp-action="Detalii" asp-route-id="@p.Id" class="btn-outline-custom" style="padding:3px 9px;font-size:10px;">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="content-card">
            <div class="content-card-header">
                <h5>Ultimele facturi</h5>
                <a asp-controller="Facturi" asp-action="Index" class="btn-outline-custom" style="padding:4px 10px;font-size:10px;">
                    Toate <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <table class="custom-table">
                <thead><tr><th>Client</th><th>Total</th><th>Status</th></tr></thead>
                <tbody>
                @if(ViewBag.UltimiFacturi != null)
                {
                    @foreach(var f in ViewBag.UltimiFacturi)
                    {
                    <tr>
                        <td>
                            <div style="font-weight:600;font-size:13px;">@f.Programare.Masina.Client.NumeComplet</div>
                            <div style="font-size:11px;color:#aaa;">@f.SerieNumar</div>
                        </td>
                        <td style="font-weight:700;font-size:13px;">@f.Total.ToString("N0") lei</td>
                        <td>
                            <span class="badge-status @(f.StatusPlata==StatusPlata.Platita?"badge-platita":f.StatusPlata==StatusPlata.Partial?"badge-partial":"badge-neplata")">@f.StatusPlata</span>
                        </td>
                    </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-lg-8">
        <div class="content-card">
            <div class="content-card-header">
                <div><h5>Venituri lunare</h5><p>Ultimele 6 luni</p></div>
            </div>
            <div style="padding:18px 20px;">
                <canvas id="chartVenituri" height="90"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="content-card h-100">
            <div class="content-card-header">
                <div><h5>Programări</h5><p>Distribuție pe status</p></div>
            </div>
            <div style="padding:18px;display:flex;align-items:center;justify-content:center;">
                <canvas id="chartStatusuri" height="170"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    new Chart(document.getElementById('chartVenituri'), {
        type: 'bar',
        data: {
            labels: @Html.Raw(ViewBag.ProfitLunarLabels ?? "[]"),
            datasets: [{
                data: @Html.Raw(ViewBag.ProfitLunarDate ?? "[]"),
                backgroundColor: '#c1272d',
                borderRadius: 0
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, grid: { color: '#f2f2f2' }, ticks: { color: '#999', font: { size: 11 }, callback: v => v + ' lei' } },
                x: { grid: { display: false }, ticks: { color: '#999', font: { size: 11 } } }
            }
        }
    });

    new Chart(document.getElementById('chartStatusuri'), {
        type: 'doughnut',
        data: {
            labels: ['Programată', 'În lucru', 'Finalizată', 'Anulată'],
            datasets: [{
                data: [@(ViewBag.NrProgramata??0), @(ViewBag.NrInLucru??0), @(ViewBag.NrFinalizata??0), @(ViewBag.NrAnulata??0)],
                backgroundColor: ['#1a56db', '#c2410c', '#15803d', '#b91c1c'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            cutout: '65%',
            plugins: {
                legend: { position: 'bottom', labels: { color: '#666', font: { size: 11 }, padding: 12, boxWidth: 10 } }
            }
        }
    });
</script>
}
