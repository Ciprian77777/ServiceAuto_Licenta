@using ServiceAutoLicenta.Models.Entities
@{
    ViewData["Title"] = "Dashboard";
}

<!-- Page header -->
<div class="page-header">
    <div>
        <h2>Dashboard</h2>
        <p>Bine ai venit! Iată situația de astăzi.</p>
    </div>
    <a asp-controller="Programari" asp-action="Adauga" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Programare nouă
    </a>
</div>

<!-- Stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <a asp-controller="Clienti" asp-action="Index" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-icon" style="background:#eff6ff;">
                    <i class="bi bi-people-fill" style="color:#2563eb;"></i>
                </div>
                <div class="stat-value">@(ViewBag.TotalClienti ?? 0)</div>
                <div class="stat-label">Total Clienți</div>
                <div class="stat-change up">
                    <i class="bi bi-arrow-up-right"></i> activi în sistem
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a asp-controller="Masini" asp-action="Index" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-icon" style="background:#f0fdf4;">
                    <i class="bi bi-car-front-fill" style="color:#16a34a;"></i>
                </div>
                <div class="stat-value">@(ViewBag.TotalMasini ?? 0)</div>
                <div class="stat-label">Total Mașini</div>
                <div class="stat-change up">
                    <i class="bi bi-arrow-up-right"></i> înregistrate
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a asp-controller="Facturi" asp-action="Index" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-icon" style="background:#f0fdf4;">
                    <i class="bi bi-cash-stack" style="color:#16a34a;"></i>
                </div>
                <div class="stat-value">@((ViewBag.VenituriLuna as decimal? ?? 0).ToString("N0")) lei</div>
                <div class="stat-label">Venituri luna aceasta</div>
                @{
                    decimal diff = 0;
                    try
                    {
                        decimal luna = ViewBag.VenituriLuna ?? 0;
                        decimal lunaAnt = ViewBag.VenituriLunaAnt ?? 0;
                        diff = lunaAnt > 0 ? ((luna - lunaAnt) / lunaAnt * 100) : 0;
                    }
                    catch { }
                }
                @if (diff != 0)
                {
                    <div class="stat-change @(diff >= 0 ? "up" : "down")">
                        <i class="bi bi-arrow-@(diff >= 0 ? "up" : "down")-right"></i>
                        @Math.Abs(diff).ToString("N1")% față de luna trecută
                    </div>
                }
            </div>
        </a>
    </div>
    <div class="col-md-3 col-sm-6">
        <a asp-controller="Programari" asp-action="Index" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-icon" style="background:#fff7ed;">
                    <i class="bi bi-wrench-adjustable" style="color:#ea580c;"></i>
                </div>
                <div class="stat-value">@(ViewBag.ProgramariInLucru ?? 0)</div>
                <div class="stat-label">Reparații active</div>
                <div class="stat-change" style="color:#ea580c;">
                    <i class="bi bi-clock"></i> în lucru acum
                </div>
            </div>
        </a>
    </div>
</div>

<!-- Grafice -->
<div class="row g-4 mb-4">
    <div class="col-md-8">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Venituri lunare</h5>
                    <p>Ultimele 6 luni</p>
                </div>
            </div>
            <div class="p-4">
                <canvas id="chartVenituri" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Programări pe status</h5>
                    <p>Distribuție curentă</p>
                </div>
            </div>
            <div class="p-4">
                <canvas id="chartStatusuri" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Tabele -->
<div class="row g-4 mb-4">
    <!-- Ultimele programari -->
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Ultimele programări</h5>
                    <p>Activitate recentă</p>
                </div>
                <a asp-controller="Programari" asp-action="Index" class="btn-outline-custom">
                    Vezi toate
                </a>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Client / Mașină</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.UltimeProgramari != null)
                    {
                        @foreach (var p in ViewBag.UltimeProgramari)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div class="client-avatar" style="font-size:11px;">
                                            @(p.Masina.Client.Nume.Substring(0, 1))@(p.Masina.Client.Prenume.Substring(0, 1))
                                        </div>
                                        <div>
                                            <div style="font-weight:500;">@p.Masina.Client.NumeComplet</div>
                                            <div style="font-size:12px;color:var(--text-muted);">@p.Masina.NrInmatriculare</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="color:var(--text-muted);font-size:13px;">@p.DataIntrare.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <span class="badge-status @(p.Status == StatusProgramare.Finalizata ? "badge-finalizata" :
                                                                                                            p.Status == StatusProgramare.InLucru ? "badge-inlucru" :
                                                                                                            p.Status == StatusProgramare.Anulata ? "badge-anulata" : "badge-scheduled")">
                                @p.Status
                            </span>
                        </td>
                        <td>
                            <a asp-controller="Programari" asp-action="Detalii"
                               asp-route-id="@p.Id" class="btn-outline-custom" style="padding:5px 10px;">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Ultimele facturi -->
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Ultimele facturi</h5>
                    <p>Situație financiară</p>
                </div>
                <a asp-controller="Facturi" asp-action="Index" class="btn-outline-custom">
                    Vezi toate
                </a>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Client</th>
                        <th>Serie</th>
                        <th>Total</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.UltimiFacturi != null)
                    {
                        @foreach (var f in ViewBag.UltimiFacturi)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div class="client-avatar" style="font-size:11px;">
                                            @(f.Programare.Masina.Client.Nume.Substring(0, 1))@(f.Programare.Masina.Client.Prenume.Substring(0, 1))
                                        </div>
                                        <span style="font-weight:500;">@f.Programare.Masina.Client.NumeComplet</span>
                                    </div>
                                </td>
                                <td style="font-size:13px;color:var(--text-muted);">@f.SerieNumar</td>
                                <td style="font-weight:600;">@f.Total.ToString("N2") lei</td>
                                <td>
                                    <span class="badge-status @(f.StatusPlata == StatusPlata.Platita ? "badge-platita" :
                                                                                                            f.StatusPlata == StatusPlata.Partial ? "badge-partial" : "badge-neplata")">
                                @f.StatusPlata
                            </span>
                        </td>
                    </tr>
                                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Alerte stoc -->
@if ((ViewBag.AlerteStoc ?? 0) > 0)
{
    <div class="content-card mb-4">
        <div class="content-card-header" style="background:#fffbeb;border-bottom-color:#fcd34d;">
            <div style="display:flex;align-items:center;gap:10px;">
                <i class="bi bi-exclamation-triangle-fill" style="color:#d97706;font-size:18px;"></i>
                <div>
                    <h5 style="color:#92400e;">Alerte stoc scăzut</h5>
                    <p style="color:#b45309;">@ViewBag.AlerteStoc piese necesită reaprovizionare</p>
                </div>
            </div>
            <a asp-controller="Piese" asp-action="Index" asp-route-stocScazut="true"
               class="btn-outline-custom">
                Vezi toate
            </a>
        </div>
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Piesă</th>
                    <th>Cod</th>
                    <th>Stoc curent</th>
                    <th>Stoc minim</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.PieseStocScazut != null)
                {
                    @foreach (var piesa in ViewBag.PieseStocScazut)
                    {
                        <tr>
                            <td style="font-weight:500;">@piesa.Denumire</td>
                            <td style="font-size:12px;color:var(--text-muted);">@piesa.CodPiesa</td>
                            <td>
                                <span class="badge-status badge-neplata">@piesa.StocCurent buc.</span>
                            </td>
                            <td style="color:var(--text-muted);">@piesa.StocMinim buc.</td>
                            <td>
                                <a asp-controller="Piese" asp-action="Detalii"
                                   asp-route-id="@piesa.Id" class="btn-outline-custom" style="padding:5px 10px;">
                                    <i class="bi bi-box-seam"></i> Actualizează
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const labelsVenituri = @Html.Raw(ViewBag.ProfitLunarLabels ?? "[]");
        const dataVenituri = @Html.Raw(ViewBag.ProfitLunarDate ?? "[]");

        new Chart(document.getElementById('chartVenituri'), {
            type: 'line',
            data: {
                labels: labelsVenituri,
                datasets: [{
                    label: 'Venituri (lei)',
                    data: dataVenituri,
                    borderColor: '#2563eb',
                    backgroundColor: 'rgba(37,99,235,0.08)',
                    borderWidth: 2.5,
                    fill: true,
                    tension: 0.4,
                    pointBackgroundColor: '#2563eb',
                    pointRadius: 4
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(0,0,0,0.05)' },
                        ticks: { color: '#64748b', callback: v => v + ' lei' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#64748b' }
                    }
                }
            }
        });

        new Chart(document.getElementById('chartStatusuri'), {
            type: 'doughnut',
            data: {
                labels: ['Programată', 'În lucru', 'Finalizată', 'Anulată'],
                datasets: [{
                    data: [
                        @(ViewBag.NrProgramata ?? 0),
                        @(ViewBag.NrInLucru ?? 0),
                        @(ViewBag.NrFinalizata ?? 0),
                        @(ViewBag.NrAnulata ?? 0)
                    ],
                    backgroundColor: ['#2563eb', '#ea580c', '#16a34a', '#dc2626'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: '#64748b', font: { size: 12 }, padding: 16 }
                    }
                },
                cutout: '65%'
            }
        });
    </script>
}
