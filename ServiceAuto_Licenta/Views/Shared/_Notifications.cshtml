@if(TempData["Succes"]!=null||TempData["Eroare"]!=null||TempData["Info"]!=null)
{
    <div id="notif-container" style="position:fixed;top:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px;max-width:360px;">
        @if(TempData["Succes"]!=null)
        {
            <div class="notif notif-succes">
                <i class="bi bi-check-circle-fill"></i>
                <span>@TempData["Succes"]</span>
                <button onclick="this.parentElement.remove()"><i class="bi bi-x"></i></button>
            </div>
        }
        @if(TempData["Eroare"]!=null)
        {
            <div class="notif notif-eroare">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span>@TempData["Eroare"]</span>
                <button onclick="this.parentElement.remove()"><i class="bi bi-x"></i></button>
            </div>
        }
        @if(TempData["Info"]!=null)
        {
            <div class="notif notif-info">
                <i class="bi bi-info-circle-fill"></i>
                <span>@TempData["Info"]</span>
                <button onclick="this.parentElement.remove()"><i class="bi bi-x"></i></button>
            </div>
        }
    </div>
    <style>
        .notif {
            display:flex;
            align-items:center;
            gap:10px;
            padding:12px 14px;
            border-radius:10px;
            font-size:13px;
            box-shadow:0 4px 16px rgba(0,0,0,0.25);
        }
        .notif span { flex:1; }
        .notif button {
            background:none;
            border:none;
            cursor:pointer;
            font-size:16px;
            opacity:0.6;
            padding:0;
            line-height:1;
        }
        .notif button:hover { opacity:1; }
        .notif-succes { background:rgba(22,163,74,0.2);border:1px solid rgba(22,163,74,0.4);color:#86efac; }
        .notif-eroare { background:rgba(220,38,38,0.2);border:1px solid rgba(220,38,38,0.4);color:#fca5a5; }
        .notif-info { background:rgba(37,99,235,0.2);border:1px solid rgba(37,99,235,0.4);color:#93c5fd; }
    </style>
    <script>
        setTimeout(function(){
            var c=document.getElementById('notif-container');
            if(c) c.remove();
        }, 4000);
    </script>
}
