@{
    ViewData["Title"]="Asistent AI";
}

<div class="page-header">
    <div>
        <h2>Asistent AI</h2>
        <p>Intreaba orice despre clientii, masinile sau programarile tale</p>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
        <span style="width:8px;height:8px;background:#16a34a;border-radius:50%;display:inline-block;animation:pulse 2s infinite;"></span>
        <span style="font-size:13px;color:var(--text-muted);">Online</span>
    </div>
</div>

<div style="display:grid;grid-template-columns:280px 1fr;gap:20px;height:calc(100vh - 180px);">

    <div style="display:flex;flex-direction:column;gap:12px;">
        <div class="content-card" style="flex:1;overflow-y:auto;">
            <div class="content-card-header">
                <h5>Intrebari sugerate</h5>
            </div>
            <div style="padding:12px;display:flex;flex-direction:column;gap:6px;">
                @{
                    var sugestii=new[]
                    {
                                new { icon="bi-people", text="Cati clienti am inregistrati?" },
                                new { icon="bi-car-front", text="Ce masini am in sistem?" },
                                new { icon="bi-calendar-check", text="Ce programari sunt in lucru acum?" },
                                new { icon="bi-receipt", text="Ce facturi neincasate am?" },
                                new { icon="bi-gear", text="Ce piese au stoc scazut?" },
                                new { icon="bi-cash-stack", text="Care sunt veniturile mele?" },
                                new { icon="bi-person-fill", text="Arata-mi detalii despre un client" },
                                new { icon="bi-clock-history", text="Care e ultima programare?" },
                                new { icon="bi-bar-chart", text="Rezuma activitatea service-ului" },
                                };
                }
                @foreach(var s in sugestii)
                {
                    <button onclick="sendSuggestion(this.dataset.text)"
                            data-text="@s.text"
                            style="display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid var(--border-color);border-radius:8px;background:transparent;text-align:left;cursor:pointer;font-size:13px;color:var(--text-primary);transition:all 0.15s;width:100%;"
                            onmouseover="this.style.background='var(--body-bg)';this.style.borderColor='var(--blue)'"
                            onmouseout="this.style.background='transparent';this.style.borderColor='var(--border-color)'">
                        <i class="bi @s.icon" style="color:var(--blue);font-size:15px;flex-shrink:0;"></i>
                        <span>@s.text</span>
                    </button>
                }
            </div>
        </div>

        <div class="content-card" style="padding:16px;">
            <div style="font-size:12px;color:var(--text-muted);line-height:1.7;">
                <i class="bi bi-shield-check" style="color:#16a34a;margin-right:4px;"></i>
                <strong style="color:var(--text-primary);">Date private</strong><br>
                Asistentul are acces doar la datele tale din sistem.
            </div>
        </div>
    </div>

    <div class="content-card" style="display:flex;flex-direction:column;overflow:hidden;">

        <div id="chat-messages" style="flex:1;overflow-y:auto;padding:20px;display:flex;flex-direction:column;gap:16px;">

            <div style="display:flex;gap:12px;align-items:flex-start;">
                <div style="width:36px;height:36px;background:#2563eb;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-robot" style="color:white;font-size:16px;"></i>
                </div>
                <div style="max-width:70%;">
                    <div style="background:var(--body-bg);border:1px solid var(--border-color);border-radius:0 12px 12px 12px;padding:14px 16px;">
                        <p style="font-size:14px;color:var(--text-primary);margin:0 0 8px;line-height:1.6;">
                            Buna! Sunt asistentul tau virtual pentru service auto. 👋
                        </p>
                        <p style="font-size:13px;color:var(--text-muted);margin:0;line-height:1.6;">
                            Pot sa iti raspund la intrebari despre clienti, masini, programari, facturi si stocuri de piese. Incearca una din sugestiile din stanga sau scrie orice intrebare!
                        </p>
                    </div>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:4px;padding-left:4px;">Asistent AI • Acum</div>
                </div>
            </div>

        </div>

        <div id="typing-indicator" style="display:none;padding:0 20px 12px;">
            <div style="display:flex;gap:12px;align-items:flex-start;">
                <div style="width:36px;height:36px;background:#2563eb;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                    <i class="bi bi-robot" style="color:white;font-size:16px;"></i>
                </div>
                <div style="background:var(--body-bg);border:1px solid var(--border-color);border-radius:0 12px 12px 12px;padding:14px 16px;">
                    <div style="display:flex;gap:4px;align-items:center;">
                        <span style="width:7px;height:7px;background:#94a3b8;border-radius:50%;animation:bounce 1.2s infinite 0s;display:inline-block;"></span>
                        <span style="width:7px;height:7px;background:#94a3b8;border-radius:50%;animation:bounce 1.2s infinite 0.2s;display:inline-block;"></span>
                        <span style="width:7px;height:7px;background:#94a3b8;border-radius:50%;animation:bounce 1.2s infinite 0.4s;display:inline-block;"></span>
                    </div>
                </div>
            </div>
        </div>

        <div style="padding:16px 20px;border-top:1px solid var(--border-color);">
            <div style="display:flex;gap:10px;align-items:flex-end;">
                <div style="flex:1;position:relative;">
                    <textarea id="chat-input"
                              placeholder="Scrie o intrebare... (ex: Ce clienti am?, Ce masini are Ion Popescu?)"
                              rows="1"
                              style="width:100%;padding:12px 16px;border:1px solid var(--border-color);border-radius:12px;font-size:14px;resize:none;outline:none;background:var(--body-bg);color:var(--text-primary);font-family:inherit;line-height:1.5;max-height:120px;overflow-y:auto;transition:border-color 0.15s;"
                              onkeydown="handleKeyDown(event)"
                              oninput="autoResize(this)"
                              onfocus="this.style.borderColor='var(--blue)'"
                              onblur="this.style.borderColor='var(--border-color)'"></textarea>
                </div>
                <button id="send-btn" onclick="sendMessage()"
                        style="width:44px;height:44px;background:#2563eb;color:white;border:none;border-radius:12px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;transition:background 0.15s;"
                        onmouseover="this.style.background='#1d4ed8'"
                        onmouseout="this.style.background='#2563eb'">
                    <i class="bi bi-send-fill"></i>
                </button>
            </div>
            <div style="font-size:11px;color:var(--text-muted);margin-top:6px;text-align:center;">
                Apasa Enter pentru a trimite • Shift+Enter pentru linie noua
            </div>
        </div>
    </div>
</div>

<style>
    @@keyframes bounce {
        0%, 60%, 100% {
            transform: translateY(0);
        }

        30% {
            transform: translateY(-6px);
        }
    }

    @@keyframes pulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.4;
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .chat-message-new {
        animation: fadeIn 0.3s ease forwards;
    }

    #chat-messages::-webkit-scrollbar {
        width: 4px;
    }

    #chat-messages::-webkit-scrollbar-track {
        background: transparent;
    }

    #chat-messages::-webkit-scrollbar-thumb {
        background: var(--border-color);
        border-radius: 2px;
    }
</style>

@section Scripts {
    <script>
        let isLoading=false;

        function handleKeyDown(e){
            if(e.key === 'Enter'&&!e.shiftKey){
                e.preventDefault();
                sendMessage();
            }
        }

        function autoResize(el){
            el.style.height='auto';
            el.style.height=Math.min(el.scrollHeight, 120) + 'px';
        }

        function sendSuggestion(text){
            document.getElementById('chat-input').value=text;
            sendMessage();
        }

        function sendMessage(){
            if(isLoading) return;

            const input=document.getElementById('chat-input');
            const message=input.value.trim();
            if(!message) return;

            appendMessage('user', message);
            input.value='';
            input.style.height='auto';

            isLoading=true;
            document.getElementById('typing-indicator').style.display='block';
            document.getElementById('send-btn').disabled=true;
            document.getElementById('send-btn').style.opacity='0.5';
            scrollToBottom();

            fetch('/Chatbot/Ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ message: message })
            })
            .then(r=>r.json())
            .then(data=>{
                document.getElementById('typing-indicator').style.display='none';
                isLoading=false;
                document.getElementById('send-btn').disabled=false;
                document.getElementById('send-btn').style.opacity='1';

                if(data.success){
                    appendMessage('assistant', data.message);
                } else{
                    appendMessage('error', data.message||'A aparut o eroare. Incearca din nou.');
                }
            })
            .catch(()=>{
                document.getElementById('typing-indicator').style.display='none';
                isLoading=false;
                document.getElementById('send-btn').disabled=false;
                document.getElementById('send-btn').style.opacity='1';
                appendMessage('error', 'Nu am putut contacta serverul. Verifica conexiunea.');
            });
        }

        function appendMessage(role, text){
            const container=document.getElementById('chat-messages');
            const now=new Date().toLocaleTimeString('ro-RO', { hour: '2-digit', minute: '2-digit' });

            if(role === 'user'){
                container.insertAdjacentHTML('beforeend', `
                    <div class="chat-message-new" style="display:flex;justify-content:flex-end;gap:12px;align-items:flex-start;">
                        <div style="max-width:70%;">
                            <div style="background:#2563eb;color:white;border-radius:12px 0 12px 12px;padding:12px 16px;">
                                <p style="font-size:14px;margin:0;line-height:1.6;">${escapeHtml(text)}</p>
                            </div>
                            <div style="font-size:11px;color:var(--text-muted);margin-top:4px;text-align:right;padding-right:4px;">Tu • ${now}</div>
                        </div>
                        <div style="width:36px;height:36px;background:#e2e8f0;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-person-fill" style="color:#64748b;font-size:16px;"></i>
                        </div>
                    </div>
                `);
            } else if(role === 'assistant'){
                const formattedText=formatMessage(text);
                container.insertAdjacentHTML('beforeend', `
                    <div class="chat-message-new" style="display:flex;gap:12px;align-items:flex-start;">
                        <div style="width:36px;height:36px;background:#2563eb;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                            <i class="bi bi-robot" style="color:white;font-size:16px;"></i>
                        </div>
                        <div style="max-width:75%;">
                            <div style="background:var(--body-bg);border:1px solid var(--border-color);border-radius:0 12px 12px 12px;padding:14px 16px;">
                                <div style="font-size:14px;color:var(--text-primary);line-height:1.7;">${formattedText}</div>
                            </div>
                            <div style="font-size:11px;color:var(--text-muted);margin-top:4px;padding-left:4px;">Asistent AI • ${now}</div>
                        </div>
                    </div>
                `);
            } else{
                container.insertAdjacentHTML('beforeend', `
                    <div class="chat-message-new" style="display:flex;justify-content:center;">
                        <div style="background:rgba(220,38,38,0.15);border:1px solid rgba(220,38,38,0.3);border-radius:8px;padding:10px 16px;font-size:13px;color:#fca5a5;">
                            <i class="bi bi-exclamation-circle me-2"></i>${escapeHtml(text)}
                        </div>
                    </div>
                `);
            }

            scrollToBottom();
        }

        function formatMessage(text){
            let formatted=escapeHtml(text);

            formatted=formatted.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');

            formatted=formatted.replace(/^- (.+)$/gm, '<li style="margin-left:16px;margin-bottom:4px;">$1</li>');
            formatted=formatted.replace(/(<li.*<\/li>\n?)+/g, '<ul style="margin:8px 0;padding:0;">$&</ul>');

            formatted=formatted.replace(/\n\n/g, '<br><br>');
            formatted=formatted.replace(/\n/g, '<br>');

            return formatted;
        }

        function escapeHtml(text){
            const div=document.createElement('div');
            div.textContent=text;
            return div.innerHTML;
        }

        function scrollToBottom(){
            const container=document.getElementById('chat-messages');
            setTimeout(()=>{
                container.scrollTop=container.scrollHeight;
            }, 50);
        }

        document.addEventListener('DOMContentLoaded', ()=>{
            document.getElementById('chat-input').focus();
        });
    </script>
}
