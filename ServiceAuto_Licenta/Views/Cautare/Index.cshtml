@model ServiceAutoLicenta.Controllers.SearchResult
@using ServiceAutoLicenta.Models.Entities
@{
    ViewData["Title"]="Cautare";
}

<div class="page-header">
    <div>
        <h2>Rezultate cautare</h2>
        @if(!string.IsNullOrEmpty(Model.Query))
        {
            <p>
                @if(Model.TotalRezultate > 0)
                {
                    <span>@Model.TotalRezultate rezultate pentru „<strong>@Model.Query</strong>"</span>
                }
                else
                {
                    <span>Niciun rezultat pentru „<strong>@Model.Query</strong>"</span>
                }
            </p>
        }
        else
        {
            <p>Scrie ceva in bara de cautare pentru a incepe</p>
        }
    </div>
</div>

<div class="content-card mb-4" style="padding:20px;">
    <form method="get" asp-controller="Cautare" asp-action="Index">
        <div style="display:flex;gap:10px;">
            <div style="flex:1;position:relative;">
                <i class="bi bi-search" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:16px;"></i>
                <input type="text" name="q" value="@Model.Query" autofocus
                       style="width:100%;padding:12px 16px 12px 42px;border:1px solid var(--border-color);border-radius:10px;font-size:15px;outline:none;background:var(--body-bg);color:var(--text-primary);"
                       placeholder="Cauta clienti, masini, programari, piese..." />
            </div>
            <button type="submit" class="btn-primary-custom" style="padding:12px 24px;font-size:15px;">
                <i class="bi bi-search me-1"></i> Cauta
            </button>
            @if(!string.IsNullOrEmpty(Model.Query))
            {
                <a asp-controller="Cautare" asp-action="Index" class="btn-outline-custom" style="padding:12px 16px;">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </div>
    </form>
</div>

@if(string.IsNullOrEmpty(Model.Query))
{
    <div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
        <i class="bi bi-search" style="font-size:3rem;opacity:0.2;"></i>
        <p style="margin-top:16px;font-size:15px;">Cauta in toata aplicatia</p>
        <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:20px;">
            @foreach(var hint in new[] { "Ion Popescu", "CJ 01 ABC", "Filtru ulei", "SA-2024" })
            {
                <a href="?q=@hint" style="background:var(--body-bg);border:1px solid var(--border-color);border-radius:20px;padding:6px 14px;font-size:13px;color:var(--text-muted);text-decoration:none;">
                    @hint
                </a>
            }
        </div>
    </div>
}
else if(Model.TotalRezultate==0)
{
    <div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
        <i class="bi bi-emoji-frown" style="font-size:3rem;opacity:0.2;"></i>
        <p style="margin-top:16px;font-size:15px;">Niciun rezultat pentru „@Model.Query"</p>
        <p style="font-size:13px;">Incearca sa cauti dupa alt termen</p>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;gap:20px;">

        @if(Model.Clienti.Any())
        {
            <div class="content-card">
                <div class="content-card-header">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="width:32px;height:32px;background:rgba(37,99,235,0.25);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-people-fill" style="color:#2563eb;font-size:14px;"></i>
                        </div>
                        <h5>Clienti (@Model.Clienti.Count)</h5>
                    </div>
                    <a asp-controller="Clienti" asp-action="Index" asp-route-cautare="@Model.Query"
                       class="btn-outline-custom" style="font-size:12px;padding:5px 12px;">
                        Vezi toti
                    </a>
                </div>
                <table class="custom-table">
                    <tbody>
                        @foreach(var c in Model.Clienti)
                        {
                            <tr>
                                <td>
                                    <div style="display:flex;align-items:center;gap:10px;">
                                        <div class="client-avatar" style="font-size:11px;">
                                            @(c.Nume.Substring(0, 1))@(c.Prenume.Substring(0, 1))
                                        </div>
                                        <div>
                                            <div style="font-weight:500;">@c.NumeComplet</div>
                                            <div style="font-size:12px;color:var(--text-muted);">@c.Telefon</div>
                                        </div>
                                    </div>
                                </td>
                                <td style="color:var(--text-muted);font-size:13px;">@(c.Email??"-")</td>
                                <td>
                                    <span style="background:rgba(37,99,235,0.3);color:#93c5fd;padding:3px 10px;border-radius:20px;font-size:12px;">
                                        @c.Masini.Count masini
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="Clienti" asp-action="Detalii" asp-route-id="@c.Id"
                                       class="btn-outline-custom" style="padding:5px 10px;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if(Model.Masini.Any())
        {
            <div class="content-card">
                <div class="content-card-header">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="width:32px;height:32px;background:rgba(22,163,74,0.25);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-car-front-fill" style="color:#16a34a;font-size:14px;"></i>
                        </div>
                        <h5>Masini (@Model.Masini.Count)</h5>
                    </div>
                    <a asp-controller="Masini" asp-action="Index" asp-route-cautare="@Model.Query"
                       class="btn-outline-custom" style="font-size:12px;padding:5px 12px;">
                        Vezi toate
                    </a>
                </div>
                <table class="custom-table">
                    <tbody>
                        @foreach(var m in Model.Masini)
                        {
                            <tr>
                                <td>
                                    <span style="font-family:monospace;font-weight:600;background:rgba(255,255,255,0.12);padding:3px 10px;border-radius:6px;font-size:13px;">
                                        @m.NrInmatriculare
                                    </span>
                                </td>
                                <td>
                                    <div style="font-weight:500;">@m.Marca @m.ModelMasina</div>
                                    <div style="font-size:12px;color:var(--text-muted);">@m.AnFabricatie</div>
                                </td>
                                <td style="font-size:13px;color:var(--text-muted);">@m.Client.NumeComplet</td>
                                <td>
                                    <a asp-controller="Masini" asp-action="Detalii" asp-route-id="@m.Id"
                                       class="btn-outline-custom" style="padding:5px 10px;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if(Model.Programari.Any())
        {
            <div class="content-card">
                <div class="content-card-header">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="width:32px;height:32px;background:rgba(234,88,12,0.25);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-calendar-check-fill" style="color:#ea580c;font-size:14px;"></i>
                        </div>
                        <h5>Programari (@Model.Programari.Count)</h5>
                    </div>
                    <a asp-controller="Programari" asp-action="Index" asp-route-cautare="@Model.Query"
                       class="btn-outline-custom" style="font-size:12px;padding:5px 12px;">
                        Vezi toate
                    </a>
                </div>
                <table class="custom-table">
                    <tbody>
                        @foreach(var p in Model.Programari)
                        {
                            <tr>
                                <td style="font-size:13px;color:var(--text-muted);">@p.DataIntrare.ToString("dd.MM.yyyy")</td>
                                <td>
                                    <div style="font-weight:500;">@p.Masina.Client.NumeComplet</div>
                                    <div style="font-size:12px;color:var(--text-muted);">@p.Masina.NrInmatriculare</div>
                                </td>
                                <td>
                                    <span class="badge-status @(p.Status==StatusProgramare.Finalizata?"badge-finalizata":p.Status==StatusProgramare.InLucru?"badge-inlucru":p.Status==StatusProgramare.Anulata?"badge-anulata":"badge-scheduled")">
                            @p.Status
                        </span>
                    </td>
                    <td style="font-weight:600;">@p.TotalCuTva.ToString("N2") lei</td>
                    <td>
                        <a asp-controller="Programari" asp-action="Detalii" asp-route-id="@p.Id"
                           class="btn-outline-custom" style="padding:5px 10px;">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
                                }
                    </tbody>
                </table>
            </div>
        }

        @if(Model.Piese.Any())
        {
            <div class="content-card">
                <div class="content-card-header">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="width:32px;height:32px;background:rgba(124,58,237,0.25);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-gear-fill" style="color:#7c3aed;font-size:14px;"></i>
                        </div>
                        <h5>Piese (@Model.Piese.Count)</h5>
                    </div>
                    <a asp-controller="Piese" asp-action="Index" asp-route-cautare="@Model.Query"
                       class="btn-outline-custom" style="font-size:12px;padding:5px 12px;">
                        Vezi toate
                    </a>
                </div>
                <table class="custom-table">
                    <tbody>
                        @foreach(var p in Model.Piese)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:500;">@p.Denumire</div>
                                    <div style="font-size:12px;color:var(--text-muted);font-family:monospace;">@p.CodPiesa</div>
                                </td>
                                <td style="font-size:13px;color:var(--text-muted);">@(p.Producator??"-")</td>
                                <td>
                                    @if(p.StocCurent==0)
                                    {
                                        <span style="background:rgba(220,38,38,0.3);color:#fca5a5;padding:3px 10px;border-radius:20px;font-size:12px;">Epuizat</span>
                                    }
                                    else if(p.StocScazut)
                                    {
                                        <span style="background:rgba(252,211,77,0.15);color:#fcd34d;padding:3px 10px;border-radius:20px;font-size:12px;">Stoc scazut (@p.StocCurent)</span>
                                    }
                                    else
                                    {
                                        <span style="background:rgba(22,163,74,0.3);color:#86efac;padding:3px 10px;border-radius:20px;font-size:12px;">In stoc (@p.StocCurent)</span>
                                    }
                                </td>
                                <td style="font-weight:600;">@p.PretVanzare.ToString("N2") lei</td>
                                <td>
                                    <a asp-controller="Piese" asp-action="Detalii" asp-route-id="@p.Id"
                                       class="btn-outline-custom" style="padding:5px 10px;">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if(Model.Facturi.Any())
        {
            <div class="content-card">
                <div class="content-card-header">
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="width:32px;height:32px;background:rgba(22,163,74,0.25);border-radius:8px;display:flex;align-items:center;justify-content:center;">
                            <i class="bi bi-receipt-cutoff" style="color:#16a34a;font-size:14px;"></i>
                        </div>
                        <h5>Facturi (@Model.Facturi.Count)</h5>
                    </div>
                    <a asp-controller="Facturi" asp-action="Index" asp-route-cautare="@Model.Query"
                       class="btn-outline-custom" style="font-size:12px;padding:5px 12px;">
                        Vezi toate
                    </a>
                </div>
                <table class="custom-table">
                    <tbody>
                        @foreach(var f in Model.Facturi)
                        {
                            <tr>
                                <td>
                                    <span style="font-family:monospace;font-weight:600;background:rgba(255,255,255,0.12);padding:3px 8px;border-radius:4px;font-size:12px;">
                                        @f.SerieNumar
                                    </span>
                                </td>
                                <td style="font-size:13px;">@f.Programare.Masina.Client.NumeComplet</td>
                                <td style="font-size:13px;color:var(--text-muted);">@f.DataEmitere.ToString("dd.MM.yyyy")</td>
                                <td style="font-weight:600;">@f.Total.ToString("N2") lei</td>
                                <td>
                                    <span class="badge-status @(f.StatusPlata==StatusPlata.Platita?"badge-platita":f.StatusPlata==StatusPlata.Partial?"badge-partial":"badge-neplata")">
                            @f.StatusPlata
                        </span>
                    </td>
                    <td>
                        <a asp-controller="Facturi" asp-action="Detalii" asp-route-id="@f.Id"
                           class="btn-outline-custom" style="padding:5px 10px;">
                            <i class="bi bi-eye"></i>
                        </a>
                    </td>
                </tr>
                                }
                    </tbody>
                </table>
            </div>
        }

    </div>
}
