@model ServiceAutoLicenta.Models.Entities.Programare
@using ServiceAutoLicenta.Models.Entities
@{
    ViewData["Title"] = "Programare #" + Model.Id;
}

<div class="page-header">
    <div style="display:flex;align-items:center;gap:12px;">
        <a asp-action="Index" class="btn-outline-custom" style="padding:8px 12px;">
            <i class="bi bi-arrow-left"></i>
        </a>
        <div>
            <h2>Programare #@Model.Id</h2>
            <p>@Model.DataIntrare.ToString("dd MMMM yyyy") — @Model.Masina.NrInmatriculare</p>
        </div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
        <span class="badge-status @(Model.Status == StatusProgramare.Finalizata ? "badge-finalizata" :
                                                   Model.Status == StatusProgramare.InLucru ? "badge-inlucru" :
                                                   Model.Status == StatusProgramare.Anulata ? "badge-anulata" : "badge-scheduled")"
              style="font-size:13px;padding:6px 14px;">
            @Model.Status
        </span>
        <a asp-action="Editeaza" asp-route-id="@Model.Id" class="btn-outline-custom">
            <i class="bi bi-pencil"></i> Editează
        </a>
    </div>
</div>

@if (TempData["Succes"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Eroare"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Eroare"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-4">
        <!-- Info programare -->
        <div class="content-card mb-4">
            <div class="content-card-header"><h5>Detalii programare</h5></div>
            <div style="padding:20px;display:flex;flex-direction:column;gap:12px;">
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Data intrare</span>
                    <strong>@Model.DataIntrare.ToString("dd.MM.yyyy")</strong>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Data ieșire</span>
                    <span>@(Model.DataIesire?.ToString("dd.MM.yyyy") ?? "-")</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Observatii))
                {
                    <div style="font-size:14px;">
                        <span style="color:var(--text-muted);display:block;margin-bottom:4px;">Observații</span>
                        <span>@Model.Observatii</span>
                    </div>
                }
            </div>
        </div>

        <!-- Mașină + Client -->
        <div class="content-card mb-4">
            <div class="content-card-header"><h5>Vehicul & Client</h5></div>
            <div style="padding:20px;">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                    <div style="width:44px;height:44px;background:#f1f5f9;border-radius:10px;display:flex;align-items:center;justify-content:center;">
                        <i class="bi bi-car-front" style="font-size:20px;color:var(--text-muted);"></i>
                    </div>
                    <div>
                        <div style="font-weight:600;">@Model.Masina.Marca @Model.Masina.ModelMasina</div>
                        <div style="font-size:13px;color:var(--text-muted);">@Model.Masina.NrInmatriculare</div>
                    </div>
                </div>
                <div style="display:flex;align-items:center;gap:12px;">
                    <div class="client-avatar" style="width:44px;height:44px;font-size:15px;">
                        @(Model.Masina.Client.Nume.Substring(0, 1))@(Model.Masina.Client.Prenume.Substring(0, 1))
                    </div>
                    <div>
                        <div style="font-weight:600;">@Model.Masina.Client.NumeComplet</div>
                        <div style="font-size:13px;color:var(--text-muted);">@Model.Masina.Client.Telefon</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total + Factură -->
        <div class="content-card" style="border:1.5px solid #2563eb;">
            <div class="content-card-header" style="background:#eff6ff;">
                <h5 style="color:#1d4ed8;">Total programare</h5>
            </div>
            <div style="padding:20px;">
                <div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:8px;">
                    <span style="color:var(--text-muted);">Fără TVA</span>
                    <span>@Model.TotalFaraTva.ToString("N2") lei</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;margin-bottom:12px;">
                    <span style="color:var(--text-muted);">TVA (19%)</span>
                    <span>@Model.Tva.ToString("N2") lei</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:18px;font-weight:700;padding-top:12px;border-top:1px solid var(--border-color);">
                    <span>Total</span>
                    <span style="color:#2563eb;">@Model.TotalCuTva.ToString("N2") lei</span>
                </div>

                @if (Model.Factura == null && Model.Status == StatusProgramare.Finalizata)
                {
                    <a asp-controller="Facturi" asp-action="Genereaza" asp-route-programareId="@Model.Id"
                       class="btn-primary-custom" style="width:100%;justify-content:center;margin-top:16px;">
                        <i class="bi bi-file-earmark-text"></i> Generează factură
                    </a>
                }
                @if (Model.Factura != null)
                {
                    <a asp-controller="Facturi" asp-action="Detalii" asp-route-id="@Model.Factura.Id"
                       class="btn-outline-custom" style="width:100%;justify-content:center;margin-top:16px;color:#16a34a;border-color:#86efac;">
                        <i class="bi bi-file-earmark-check"></i> Vezi factura
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Lucrări -->
    <div class="col-md-8">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Lucrări & Piese</h5>
                    <p>@Model.Lucrari.Count lucrări înregistrate</p>
                </div>
            </div>
            <div style="padding:20px;display:flex;flex-direction:column;gap:16px;">

                @foreach (var lucrare in Model.Lucrari)
                {
                    <div style="border:1px solid var(--border-color);border-radius:10px;overflow:hidden;">
                        <div style="padding:14px 16px;background:#f8fafc;display:flex;justify-content:space-between;align-items:center;">
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div style="width:32px;height:32px;background:#eff6ff;border-radius:8px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-wrench" style="color:#2563eb;font-size:14px;"></i>
                                </div>
                                <div>
                                    <div style="font-weight:600;font-size:14px;">@lucrare.Denumire</div>
                                    @if (!string.IsNullOrEmpty(lucrare.Descriere))
                                    {
                                        <div style="font-size:12px;color:var(--text-muted);">@lucrare.Descriere</div>
                                    }
                                </div>
                            </div>
                            <div style="display:flex;align-items:center;gap:12px;">
                                <div style="text-align:right;">
                                    <div style="font-size:13px;color:var(--text-muted);">Manoperă</div>
                                    <div style="font-weight:600;color:#2563eb;">@lucrare.Manopera.ToString("N2") lei</div>
                                </div>
                                <form asp-action="StergeLucrare" method="post">
                                    <input type="hidden" name="lucrareId" value="@lucrare.Id" />
                                    <input type="hidden" name="programareId" value="@Model.Id" />
                                    <button type="submit" class="btn-outline-custom"
                                            style="padding:5px 10px;color:#ef4444;border-color:#fca5a5;"
                                            onclick="return confirm('Ștergi lucrarea?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        @if (lucrare.LucrarePiese.Any())
                        {
                            <div style="padding:0 16px;">
                                <table style="width:100%;border-collapse:collapse;">
                                    <thead>
                                        <tr style="border-bottom:1px solid var(--border-color);">
                                            <th style="padding:8px 0;font-size:11px;color:var(--text-muted);font-weight:600;text-transform:uppercase;">Piesă</th>
                                            <th style="padding:8px 0;font-size:11px;color:var(--text-muted);font-weight:600;text-transform:uppercase;text-align:center;">Cant.</th>
                                            <th style="padding:8px 0;font-size:11px;color:var(--text-muted);font-weight:600;text-transform:uppercase;text-align:right;">Subtotal</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var lp in lucrare.LucrarePiese)
                                        {
                                            <tr style="border-bottom:1px solid var(--border-color);">
                                                <td style="padding:10px 0;font-size:13px;">@lp.Piesa.Denumire</td>
                                                <td style="padding:10px 0;font-size:13px;text-align:center;">@lp.Cantitate buc.</td>
                                                <td style="padding:10px 0;font-size:13px;text-align:right;font-weight:500;">@lp.Subtotal.ToString("N2") lei</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }

                        <!-- Adaugă piesă -->
                        <div style="padding:12px 16px;background:#fafafa;border-top:1px solid var(--border-color);">
                            <form asp-action="AdaugaPiesa" method="post">
                                <input type="hidden" name="lucrareId" value="@lucrare.Id" />
                                <input type="hidden" name="programareId" value="@Model.Id" />
                                <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                                    <select name="piesaId" style="flex:2;min-width:180px;padding:7px 10px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;">
                                        <option value="">-- Selectează piesa --</option>
                                        @foreach (var piesa in ViewBag.Piese as IEnumerable<ServiceAutoLicenta.Models.Entities.Piesa> ?? new List<ServiceAutoLicenta.Models.Entities.Piesa>())
                                        {
                                            <option value="@piesa.Id">@piesa.Denumire (stoc: @piesa.StocCurent)</option>
                                        }
                                    </select>
                                    <input type="number" name="cantitate" value="1" min="1"
                                           style="width:70px;padding:7px 10px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;" />
                                    <button type="submit" class="btn-outline-custom" style="padding:7px 14px;">
                                        <i class="bi bi-plus-lg"></i> Adaugă piesă
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                }

                <!-- Formular lucrare nouă -->
                <div style="border:2px dashed var(--border-color);border-radius:10px;padding:16px;">
                    <div style="font-weight:600;font-size:14px;margin-bottom:12px;color:var(--text-muted);">
                        <i class="bi bi-plus-circle me-2"></i>Adaugă lucrare nouă
                    </div>
                    <form asp-action="AdaugaLucrare" method="post">
                        <input type="hidden" name="programareId" value="@Model.Id" />
                        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:8px;">
                            <input type="text" name="denumire" required
                                   style="flex:2;min-width:200px;padding:8px 12px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;"
                                   placeholder="Denumire lucrare *" />
                            <input type="number" name="manopera" step="0.01" min="0" value="0"
                                   style="width:120px;padding:8px 12px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;"
                                   placeholder="Manoperă (lei)" />
                            <input type="number" name="durataOre" step="0.5" min="0" value="0"
                                   style="width:90px;padding:8px 12px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;"
                                   placeholder="Ore" />
                        </div>
                        <div style="display:flex;gap:8px;">
                            <textarea name="descriere" rows="2"
                                      style="flex:1;padding:8px 12px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;"
                                      placeholder="Descriere (opțional)"></textarea>
                            <button type="submit" class="btn-primary-custom" style="align-self:flex-end;">
                                <i class="bi bi-check-lg"></i> Adaugă
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>