@model IEnumerable<ServiceAutoLicenta.Models.Entities.Programare>
@using ServiceAutoLicenta.Models.Entities
@{
    ViewData["Title"] = "Programări";
}

<div class="page-header">
    <div>
        <h2>Appointments</h2>
        <p>Gestionează programările service-ului</p>
    </div>
    <a asp-action="Adauga" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Programare nouă
    </a>
</div>

@if (TempData["Succes"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Eroare"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Eroare"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filtre status -->
<div style="display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;">
    <a asp-action="Index" class="btn-outline-custom @(string.IsNullOrEmpty(ViewBag.Status) ? "active-filter" : "")">
        Toate <span style="background:#e2e8f0;padding:1px 8px;border-radius:20px;font-size:11px;margin-left:4px;">@Model.Count()</span>
    </a>
    <a asp-action="Index" asp-route-status="Programata" class="btn-outline-custom @(ViewBag.Status == "Programata" ? "active-filter" : "")">
        <span style="width:8px;height:8px;background:#2563eb;border-radius:50%;display:inline-block;margin-right:4px;"></span>
        Programată <span style="background:#e2e8f0;padding:1px 8px;border-radius:20px;font-size:11px;margin-left:4px;">@Model.Count(p => p.Status == StatusProgramare.Programata)</span>
    </a>
    <a asp-action="Index" asp-route-status="InLucru" class="btn-outline-custom @(ViewBag.Status == "InLucru" ? "active-filter" : "")">
        <span style="width:8px;height:8px;background:#ea580c;border-radius:50%;display:inline-block;margin-right:4px;"></span>
        În lucru <span style="background:#e2e8f0;padding:1px 8px;border-radius:20px;font-size:11px;margin-left:4px;">@Model.Count(p => p.Status == StatusProgramare.InLucru)</span>
    </a>
    <a asp-action="Index" asp-route-status="Finalizata" class="btn-outline-custom @(ViewBag.Status == "Finalizata" ? "active-filter" : "")">
        <span style="width:8px;height:8px;background:#16a34a;border-radius:50%;display:inline-block;margin-right:4px;"></span>
        Finalizată <span style="background:#e2e8f0;padding:1px 8px;border-radius:20px;font-size:11px;margin-left:4px;">@Model.Count(p => p.Status == StatusProgramare.Finalizata)</span>
    </a>
</div>

<!-- Căutare -->
<div class="content-card" style="margin-bottom:16px;">
    <div style="padding:14px 20px;">
        <form method="get" style="display:flex;gap:8px;align-items:center;">
            <input type="hidden" name="status" value="@ViewBag.Status" />
            <div style="position:relative;flex:1;max-width:360px;">
                <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:14px;"></i>
                <input type="text" name="cautare" value="@ViewBag.Cautare"
                       style="padding:8px 12px 8px 32px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;width:100%;outline:none;"
                       placeholder="Caută după client sau nr. înmatriculare..." />
            </div>
            <button type="submit" class="btn-outline-custom">Caută</button>
            @if (!string.IsNullOrEmpty(ViewBag.Cautare))
            {
                <a asp-action="Index" asp-route-status="@ViewBag.Status" class="btn-outline-custom" style="color:#ef4444;border-color:#fca5a5;">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>
</div>

<!-- Lista programări ca carduri -->
@if (!Model.Any())
{
    <div class="content-card" style="text-align:center;padding:60px 20px;color:var(--text-muted);">
        <i class="bi bi-calendar-x" style="font-size:3rem;opacity:0.3;"></i>
        <p style="margin-top:12px;">Nu există programări.</p>
        <a asp-action="Adauga" class="btn-primary-custom" style="margin-top:8px;">
            <i class="bi bi-plus-lg"></i> Adaugă programare
        </a>
    </div>
}
else
{
    <div style="display:flex;flex-direction:column;gap:12px;">
        @foreach (var p in Model)
        {
            <div class="content-card" style="padding:0;">
                <div style="display:flex;align-items:center;padding:18px 20px;gap:20px;">
                    <!-- Data -->
                    <div style="background:var(--blue);color:white;border-radius:10px;padding:8px 14px;text-align:center;min-width:60px;flex-shrink:0;">
                        <div style="font-size:11px;opacity:0.8;text-transform:uppercase;">@p.DataIntrare.ToString("MMM")</div>
                        <div style="font-size:22px;font-weight:700;line-height:1;">@p.DataIntrare.Day</div>
                    </div>

                    <!-- Client + Masina -->
                    <div style="flex:1;min-width:0;">
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;">
                            <div class="client-avatar" style="font-size:11px;width:28px;height:28px;">
                                @(p.Masina.Client.Nume.Substring(0, 1))@(p.Masina.Client.Prenume.Substring(0, 1))
                            </div>
                            <span style="font-weight:600;font-size:14px;">@p.Masina.Client.NumeComplet</span>
                        </div>
                        <div style="display:flex;gap:16px;font-size:13px;color:var(--text-muted);">
                            <span><i class="bi bi-car-front me-1"></i>@p.Masina.Marca @p.Masina.ModelMasina</span>
                            <span><i class="bi bi-tag me-1"></i>@p.Masina.NrInmatriculare</span>
                            @if (!string.IsNullOrEmpty(p.Observatii))
                            {
                                <span><i class="bi bi-chat-text me-1"></i>@p.Observatii</span>
                            }
                        </div>
                    </div>

                    <!-- Status + Total + Actiuni -->
                    <div style="display:flex;align-items:center;gap:16px;flex-shrink:0;">
                        <span class="badge-status @(p.Status == StatusProgramare.Finalizata ? "badge-finalizata" :
                                                                                   p.Status == StatusProgramare.InLucru ? "badge-inlucru" :
                                                                                   p.Status == StatusProgramare.Anulata ? "badge-anulata" : "badge-scheduled")">
                    @p.Status
                </span>
                <div style="text-align:right;">
                    <div style="font-weight:600;font-size:14px;">@p.TotalCuTva.ToString("N2") lei</div>
                    <div style="font-size:12px;color:var(--text-muted);">total cu TVA</div>
                </div>
                <div style="display:flex;gap:6px;">
                    <a asp-action="Detalii" asp-route-id="@p.Id"
                       class="btn-outline-custom" style="padding:6px 12px;">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a asp-action="Editeaza" asp-route-id="@p.Id"
                       class="btn-outline-custom" style="padding:6px 12px;">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <a asp-action="Sterge" asp-route-id="@p.Id"
                       class="btn-outline-custom" style="padding:6px 12px;color:#ef4444;border-color:#fca5a5;">
                        <i class="bi bi-trash"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
        }
    </div>
    <p style="font-size:13px;color:var(--text-muted);margin-top:12px;">Total: @Model.Count() programări</p>
}

<style>
    .active-filter {
        background: var(--blue) !important;
        color: white !important;
        border-color: var(--blue) !important;
    }
</style>