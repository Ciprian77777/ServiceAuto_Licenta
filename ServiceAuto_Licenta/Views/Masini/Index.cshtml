@model IEnumerable<ServiceAutoLicenta.Models.Entities.Masina>
@{
    ViewData["Title"]="Ma?ini";
}

<div class="page-header">
    <div>
        <h2>Ma?ini</h2>
        <p>Gestioneaza vehiculele înregistrate</p>
    </div>
    <a asp-action="Adauga" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Ma?ina noua
    </a>
</div>

@if(TempData["Succes"]!=null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if(TempData["Eroare"]!=null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Eroare"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-with-stats">
    <aside class="pstats">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-car-front-fill"></i></div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Total Ma?ini</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-people-fill"></i></div>
            <div class="stat-value">@Model.Select(m=>m.ClientId).Distinct().Count()</div>
            <div class="stat-label">Proprietari unici</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-calendar-check"></i></div>
            <div class="stat-value">@Model.Sum(m=>m.Programari.Count)</div>
            <div class="stat-label">Total programari</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-calendar-plus"></i></div>
            <div class="stat-value">@Model.Count(m=>m.Programari.Any())</div>
            <div class="stat-label">Cu programari</div>
        </div>
    </aside>
    <div class="pmain">
    <div class="content-card">
    <div class="content-card-header">
        <form method="get" style="display:flex;gap:8px;align-items:center;">
            <div style="position:relative;">
                <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:14px;"></i>
                <input type="text" name="cautare" value="@ViewBag.Cautare"
                       style="padding:8px 12px 8px 32px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;width:280px;outline:none;"
                       placeholder="Cauta dupa nr. înmatriculare, marca, client..." />
            </div>
            <button type="submit" class="btn-outline-custom">Cauta</button>
            @if(!string.IsNullOrEmpty(ViewBag.Cautare))
            {
                <a asp-action="Index" class="btn-outline-custom" style="color:#ef4444;border-color:#fca5a5;">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
        <span style="font-size:13px;color:var(--text-muted);">@Model.Count() ma?ini gasite</span>
    </div>

    @if(!Model.Any())
    {
        <div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
            <i class="bi bi-car-front" style="font-size:3rem;opacity:0.3;"></i>
            <p style="margin-top:12px;">Nu exista ma?ini înregistrate.</p>
            <a asp-action="Adauga" class="btn-primary-custom" style="margin-top:8px;">
                <i class="bi bi-plus-lg"></i> Adauga prima ma?ina
            </a>
        </div>
    }
    else
    {
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Nr. înmatriculare</th>
                    <th>Ma?ina</th>
                    <th>Proprietar</th>
                    <th>Km</th>
                    <th>Programari</th>
                    <th>Ac?iuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var masina in Model)
                {
                    <tr>
                        <td>
                            <span style="background:rgba(255,255,255,0.12);padding:5px 12px;border-radius:6px;font-size:13px;font-weight:600;font-family:monospace;">
                                @masina.NrInmatriculare
                            </span>
                        </td>
                        <td>
                            <div style="font-weight:500;">@masina.Marca @masina.ModelMasina</div>
                            <div style="font-size:12px;color:var(--text-muted);">@masina.AnFabricatie</div>
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div class="client-avatar" style="font-size:11px;">
                                    @(masina.Client.Nume.Substring(0,1))@(masina.Client.Prenume.Substring(0,1))
                                </div>
                                <a asp-controller="Clienti" asp-action="Detalii" asp-route-id="@masina.ClientId"
                                   style="font-size:14px;color:var(--text-primary);text-decoration:none;font-weight:500;">
                                    @masina.Client.NumeComplet
                                </a>
                            </div>
                        </td>
                        <td style="font-size:13px;color:var(--text-muted);">
                            @(masina.KmActuali?.ToString("N0")??"0") km
                        </td>
                        <td style="font-size:13px;font-weight:600;color:#333;">
                            @masina.Programari.Count
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                <a asp-action="Detalii" asp-route-id="@masina.Id"
                                   class="btn-outline-custom" style="padding:5px 10px;" title="Detalii">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Editeaza" asp-route-id="@masina.Id"
                                   class="btn-outline-custom" style="padding:5px 10px;" title="Editeaza">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Sterge" asp-route-id="@masina.Id"
                                   class="btn-outline-custom" style="padding:5px 10px;color:#ef4444;border-color:#fca5a5;" title="?terge">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
    </div>
</div>
