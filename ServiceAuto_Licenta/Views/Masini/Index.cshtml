@model IEnumerable<ServiceAutoLicenta.Models.Entities.Masina>
@{
    ViewData["Title"] = "Mașini";
}

<div class="page-header">
    <div>
        <h2>Vehicle Management</h2>
        <p>Gestionează vehiculele înregistrate</p>
    </div>
    <a asp-action="Adauga" class="btn-primary-custom">
        <i class="bi bi-plus-lg"></i> Mașină nouă
    </a>
</div>

@if (TempData["Succes"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Eroare"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Eroare"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="stat-card">
            <div style="display:flex;align-items:center;gap:16px;">
                <div class="stat-icon" style="background:#f0fdf4;margin-bottom:0;">
                    <i class="bi bi-car-front-fill" style="color:#16a34a;"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size:22px;">@Model.Count()</div>
                    <div class="stat-label">Total Mașini</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div style="display:flex;align-items:center;gap:16px;">
                <div class="stat-icon" style="background:#eff6ff;margin-bottom:0;">
                    <i class="bi bi-people-fill" style="color:#2563eb;"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size:22px;">@Model.Select(m => m.ClientId).Distinct().Count()</div>
                    <div class="stat-label">Proprietari unici</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="stat-card">
            <div style="display:flex;align-items:center;gap:16px;">
                <div class="stat-icon" style="background:#fff7ed;margin-bottom:0;">
                    <i class="bi bi-calendar-check" style="color:#ea580c;"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size:22px;">@Model.Sum(m => m.Programari.Count)</div>
                    <div class="stat-label">Total programări</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tabel mașini -->
<div class="content-card">
    <div class="content-card-header">
        <form method="get" style="display:flex;gap:8px;align-items:center;">
            <div style="position:relative;">
                <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:14px;"></i>
                <input type="text" name="cautare" value="@ViewBag.Cautare"
                       style="padding:8px 12px 8px 32px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;width:280px;outline:none;"
                       placeholder="Caută după nr. înmatriculare, marcă, client..." />
            </div>
            <button type="submit" class="btn-outline-custom">Caută</button>
            @if (!string.IsNullOrEmpty(ViewBag.Cautare))
            {
                <a asp-action="Index" class="btn-outline-custom" style="color:#ef4444;border-color:#fca5a5;">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
        <span style="font-size:13px;color:var(--text-muted);">@Model.Count() mașini găsite</span>
    </div>

    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
            <i class="bi bi-car-front" style="font-size:3rem;opacity:0.3;"></i>
            <p style="margin-top:12px;">Nu există mașini înregistrate.</p>
            <a asp-action="Adauga" class="btn-primary-custom" style="margin-top:8px;">
                <i class="bi bi-plus-lg"></i> Adaugă prima mașină
            </a>
        </div>
    }
    else
    {
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Nr. înmatriculare</th>
                    <th>Mașină</th>
                    <th>Proprietar</th>
                    <th>Km</th>
                    <th>Programări</th>
                    <th>Acțiuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var masina in Model)
                {
                    <tr>
                        <td>
                            <span style="background:#f1f5f9;padding:5px 12px;border-radius:6px;font-size:13px;font-weight:600;font-family:monospace;">
                                @masina.NrInmatriculare
                            </span>
                        </td>
                        <td>
                            <div style="font-weight:500;">@masina.Marca @masina.ModelMasina</div>
                            <div style="font-size:12px;color:var(--text-muted);">@masina.AnFabricatie</div>
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div class="client-avatar" style="font-size:11px;">
                                    @(masina.Client.Nume.Substring(0, 1))@(masina.Client.Prenume.Substring(0, 1))
                                </div>
                                <a asp-controller="Clienti" asp-action="Detalii" asp-route-id="@masina.ClientId"
                                   style="font-size:14px;color:var(--text-primary);text-decoration:none;font-weight:500;">
                                    @masina.Client.NumeComplet
                                </a>
                            </div>
                        </td>
                        <td style="font-size:13px;color:var(--text-muted);">
                            @(masina.KmActuali?.ToString("N0") ?? "0") km
                        </td>
                        <td>
                            <span style="background:#eff6ff;color:#2563eb;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;">
                                @masina.Programari.Count
                            </span>
                        </td>
                        <td>
                            <div style="display:flex;gap:6px;">
                                <a asp-action="Detalii" asp-route-id="@masina.Id"
                                   class="btn-outline-custom" style="padding:5px 10px;" title="Detalii">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Editeaza" asp-route-id="@masina.Id"
                                   class="btn-outline-custom" style="padding:5px 10px;" title="Editează">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Sterge" asp-route-id="@masina.Id"
                                   class="btn-outline-custom" style="padding:5px 10px;color:#ef4444;border-color:#fca5a5;" title="Șterge">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>