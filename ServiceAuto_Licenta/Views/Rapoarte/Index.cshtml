@{
    ViewData["Title"]="Rapoarte";
}

<div class="page-header">
    <div>
        <h2>Rapoarte & Statistici</h2>
        <p>Prezentare generală a performanței business-ului</p>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
        <div style="background:rgba(255,255,255,0.08);border:1px solid var(--border-color);border-radius:8px;padding:8px 14px;font-size:13px;color:var(--text-muted);">
            <i class="bi bi-calendar3 me-2"></i>Ultimele 6 luni
        </div>
    </div>
</div>

<div class="row g-3">

    <div class="col-md-3 d-flex flex-column gap-3">
        @{
            decimal venituri = ViewBag.VenituriLuna;
            decimal profitEstimat = venituri * 0.45m;
        }
        <div class="stat-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div class="stat-icon" style="margin-bottom:0;">
                    <i class="bi bi-cash-stack"></i>
                </div>
                <span style="font-size:12px;font-weight:700;color:#15803d;">+18%</span>
            </div>
            <div class="stat-value">@venituri.ToString("N0") lei</div>
            <div class="stat-label">Venituri luna aceasta</div>
        </div>

        <div class="stat-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div class="stat-icon" style="margin-bottom:0;">
                    <i class="bi bi-graph-up-arrow"></i>
                </div>
                <span style="font-size:12px;font-weight:700;color:#15803d;">+22%</span>
            </div>
            <div class="stat-value">@profitEstimat.ToString("N0") lei</div>
            <div class="stat-label">Profit estimat (45%)</div>
        </div>

        <div class="stat-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div class="stat-icon" style="margin-bottom:0;">
                    <i class="bi bi-people-fill"></i>
                </div>
                <span style="font-size:12px;font-weight:700;color:#15803d;">+12%</span>
            </div>
            <div class="stat-value">@ViewBag.TotalClienti</div>
            <div class="stat-label">Total clienți</div>
        </div>

        <div class="stat-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div class="stat-icon" style="margin-bottom:0;">
                    <i class="bi bi-wrench-adjustable"></i>
                </div>
                <span style="font-size:12px;font-weight:700;color:#15803d;">+9%</span>
            </div>
            <div class="stat-value">@ViewBag.TotalProgramari</div>
            <div class="stat-label">Total programări</div>
        </div>
    </div>

    <div class="col-md-9">

        <div class="row g-4 mb-4">
            <div class="col-md-8">
                <div class="content-card h-100">
                    <div class="content-card-header">
                        <div>
                            <h5>Revenue vs Profit Trend</h5>
                            <p>Performanță financiară lunară — ultimele 6 luni</p>
                        </div>
                        <div style="text-align:right;">
                            <div style="font-size:11px;color:var(--text-muted);">Avg. lunar</div>
                            <div style="font-size:15px;font-weight:700;color:#2563eb;">@venituri.ToString("N0") lei</div>
                        </div>
                    </div>
                    <div style="padding:20px;">
                        <canvas id="chartVenituri" height="120"></canvas>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="content-card h-100">
                    <div class="content-card-header">
                        <div>
                            <h5>Lucrări frecvente</h5>
                            <p>Top 5 servicii</p>
                        </div>
                    </div>
                    <div style="padding:20px;">
                        <canvas id="chartLucrari" height="220"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-md-6">
                <div class="content-card">
                    <div class="content-card-header">
                        <div>
                            <h5>Top 5 piese utilizate</h5>
                            <p>După cantitate</p>
                        </div>
                    </div>
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Piesă</th>
                                <th>Cantitate</th>
                                <th>Valoare</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int i = 1;
                            }
                            @if(ViewBag.PieseTop!=null)
                            {
                                @foreach(var piesa in ViewBag.PieseTop)
                                {
                                    string bgP = "#e2e8f0"; string fgP = "var(--text-muted)";
                                    if(i==1){bgP="#fbbf24";fgP="white";}
                                    else if(i==2){bgP="#94a3b8";fgP="white";}
                                    else if(i==3){bgP="#cd7c2f";fgP="white";}
                                    <tr>
                                        <td>
                                            <span style="width:24px;height:24px;background:@bgP;color:@fgP;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">
                                                @i
                                            </span>
                                        </td>
                                        <td style="font-size:13px;font-weight:500;">@piesa.Denumire</td>
                                        <td style="font-size:13px;">@piesa.TotalCantitate buc.</td>
                                        <td style="font-size:13px;font-weight:600;">@piesa.TotalValoare.ToString("N2") lei</td>
                                    </tr>
                                    i++;
                                }
                            }
                            @if(i==1)
                            {
                                <tr><td colspan="4" style="text-align:center;color:var(--text-muted);padding:20px;">Nu există date.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="col-md-6">
                <div class="content-card">
                    <div class="content-card-header">
                        <div>
                            <h5>Top 5 clienți</h5>
                            <p>După număr de vizite</p>
                        </div>
                    </div>
                    <table class="custom-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Client</th>
                                <th>Programări</th>
                                <th>Total cheltuit</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int j = 1;
                            }
                            @if(ViewBag.ClientiTop!=null)
                            {
                                @foreach(var client in ViewBag.ClientiTop)
                                {
                                    string bgC = "#e2e8f0"; string fgC = "var(--text-muted)";
                                    if(j==1){bgC="#fbbf24";fgC="white";}
                                    else if(j==2){bgC="#94a3b8";fgC="white";}
                                    else if(j==3){bgC="#cd7c2f";fgC="white";}
                                    <tr>
                                        <td>
                                            <span style="width:24px;height:24px;background:@bgC;color:@fgC;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">
                                                @j
                                            </span>
                                        </td>
                                        <td>
                                            <div style="display:flex;align-items:center;gap:8px;">
                                                <div class="client-avatar" style="width:28px;height:28px;font-size:10px;">
                                                    @(client.Nume.Length>=2?client.Nume.Substring(0,1):"?")
                                                </div>
                                                <span style="font-size:13px;font-weight:500;">@client.Nume</span>
                                            </div>
                                        </td>
                                        <td style="font-size:13px;">@client.NrProgramari</td>
                                        <td style="font-size:13px;font-weight:600;">@client.TotalCheltuit.ToString("N2") lei</td>
                                    </tr>
                                    j++;
                                }
                            }
                            @if(j==1)
                            {
                                <tr><td colspan="4" style="text-align:center;color:var(--text-muted);padding:20px;">Nu există date.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="content-card mb-4">
            <div class="content-card-header">
                <div>
                    <h5>Top 5 lucrări efectuate</h5>
                    <p>Cele mai frecvente servicii</p>
                </div>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Lucrare</th>
                        <th>Nr. execuții</th>
                        <th>Total manoperă</th>
                        <th>Frecvență</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int k = 1; int maxCount = 1;
                    }
                    @if(ViewBag.LucrariTop!=null)
                    {
                        @foreach(var lucrare in ViewBag.LucrariTop)
                        {
                            if(k==1) maxCount=lucrare.Count;
                            string bgLuc = "#e2e8f0"; string fgLuc = "var(--text-muted)";
                            if(k==1){bgLuc="#fbbf24";fgLuc="white";}
                            else if(k==2){bgLuc="#94a3b8";fgLuc="white";}
                            else if(k==3){bgLuc="#cd7c2f";fgLuc="white";}
                            <tr>
                                <td>
                                    <span style="width:24px;height:24px;background:@bgLuc;color:@fgLuc;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">
                                        @k
                                    </span>
                                </td>
                                <td style="font-weight:500;">@lucrare.Denumire</td>
                                <td style="font-size:13px;">@lucrare.Count execuții</td>
                                <td style="font-size:13px;font-weight:600;">@lucrare.TotalManopera.ToString("N2") lei</td>
                                <td style="min-width:150px;">
                                    @{
                                        int proc = 0;
                                        if(maxCount > 0)
                                            proc = (int)(lucrare.Count * 100.0 / maxCount);
                                    }
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <div style="flex:1;background:#e2e8f0;border-radius:4px;height:6px;">
                                            <div style="width:@proc%;height:100%;background:#2563eb;border-radius:4px;"></div>
                                        </div>
                                        <span style="font-size:12px;color:var(--text-muted);min-width:30px;">@proc%</span>
                                    </div>
                                </td>
                            </tr>
                            k++;
                        }
                    }
                    @if(k==1)
                    {
                        <tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:20px;">Nu există date.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <div class="content-card">
                    <div class="content-card-header">
                        <div>
                            <h5>Distribuție programări</h5>
                            <p>După status</p>
                        </div>
                    </div>
                    <div style="padding:20px;">
                        <canvas id="chartStatusuri" height="200"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="content-card">
                    <div class="content-card-header">
                        <div>
                            <h5>Situație facturi</h5>
                            <p>Încasate vs neîncasate</p>
                        </div>
                    </div>
                    <div style="padding:20px;">
                        <canvas id="chartFacturi" height="200"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const gridColor = 'rgba(0,0,0,0.05)';
        const textColor = '#64748b';

        const labelsVenituri = @Html.Raw(ViewBag.ProfitLunarLabels ?? "[]");
        const dataVenituri = @Html.Raw(ViewBag.ProfitLunarDate ?? "[]");

        new Chart(document.getElementById('chartVenituri'), {
            type: 'line',
            data: {
                labels: labelsVenituri,
                datasets: [
                    {
                        label: 'Venituri',
                        data: dataVenituri,
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37,99,235,0.08)',
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#2563eb',
                        pointRadius: 4,
                        pointStyle: 'rect'
                    },
                    {
                        label: 'Profit estimat',
                        data: dataVenituri.map(v => Math.round(v * 0.45)),
                        borderColor: '#16a34a',
                        backgroundColor: 'rgba(22,163,74,0.06)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#16a34a',
                        pointRadius: 4,
                        pointStyle: 'rect'
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { size: 12 }, padding: 16, boxWidth: 10, usePointStyle: true }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: gridColor },
                        ticks: { color: textColor, callback: v => v + ' lei' }
                    },
                    x: { grid: { display: false }, ticks: { color: textColor } }
                }
            }
        });

        const labelsLucrari = @Html.Raw(ViewBag.LucrariTopLabels ?? "[]");
        const dataLucrari = @Html.Raw(ViewBag.LucrariTopDate ?? "[]");

        new Chart(document.getElementById('chartLucrari'), {
            type: 'doughnut',
            data: {
                labels: labelsLucrari,
                datasets: [{
                    data: dataLucrari,
                    backgroundColor: ['#2563eb', '#16a34a', '#ea580c', '#7c3aed', '#94a3b8'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { size: 11 }, padding: 12, boxWidth: 10 }
                    }
                },
                cutout: '65%'
            }
        });

        new Chart(document.getElementById('chartStatusuri'), {
            type: 'doughnut',
            data: {
                labels: ['Programată', 'În lucru', 'Finalizată', 'Anulată'],
                datasets: [{
                    data: [
                        @ViewBag.NrProgramata,
                        @ViewBag.NrInLucru,
                        @ViewBag.NrFinalizata,
                        @ViewBag.NrAnulata
                    ],
                    backgroundColor: ['#2563eb', '#ea580c', '#16a34a', '#ef4444'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { size: 12 }, padding: 16, boxWidth: 10 }
                    }
                },
                cutout: '65%'
            }
        });

        new Chart(document.getElementById('chartFacturi'), {
            type: 'doughnut',
            data: {
                labels: ['Plătite', 'Neîncasate', 'Parțial'],
                datasets: [{
                    data: [
                        @ViewBag.NrPlatite,
                        @ViewBag.NrNeplata,
                        @ViewBag.NrPartial
                    ],
                    backgroundColor: ['#16a34a', '#ef4444', '#ea580c'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { size: 12 }, padding: 16, boxWidth: 10 }
                    }
                },
                cutout: '65%'
            }
        });
    </script>
}
