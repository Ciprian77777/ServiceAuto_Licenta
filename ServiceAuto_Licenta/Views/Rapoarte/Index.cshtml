@{
    ViewData["Title"] = "Rapoarte";
}

<div class="page-header">
    <div>
        <h2>Reports & Analytics</h2>
        <p>Prezentare generală a performanței business-ului</p>
    </div>
    <div style="display:flex;align-items:center;gap:8px;">
        <div style="background:#f1f5f9;border:1px solid var(--border-color);border-radius:8px;padding:8px 14px;font-size:13px;color:var(--text-muted);">
            <i class="bi bi-calendar3 me-2"></i>Ultimele 6 luni
        </div>
    </div>
</div>

<!-- Stat cards principale -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div class="stat-icon" style="background:#eff6ff;margin-bottom:0;">
                    <i class="bi bi-cash-stack" style="color:#2563eb;"></i>
                </div>
                <span style="background:#f0fdf4;color:#16a34a;font-size:12px;font-weight:600;padding:3px 8px;border-radius:20px;">
                    +18%
                </span>
            </div>
            <div class="stat-value">@((ViewBag.VenituriLuna as decimal? ?? 0).ToString("N0")) lei</div>
            <div class="stat-label">Venituri luna aceasta</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div class="stat-icon" style="background:#f0fdf4;margin-bottom:0;">
                    <i class="bi bi-graph-up-arrow" style="color:#16a34a;"></i>
                </div>
                <span style="background:#f0fdf4;color:#16a34a;font-size:12px;font-weight:600;padding:3px 8px;border-radius:20px;">
                    +22%
                </span>
            </div>
            <div class="stat-value" style="color:#16a34a;">
                @{
                    decimal venituri = ViewBag.VenituriLuna ?? 0;
                    decimal profitEstimat = venituri * 0.45m;
                }
                @profitEstimat.ToString("N0") lei
            </div>
            <div class="stat-label">Profit estimat (45%)</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div class="stat-icon" style="background:#f5f3ff;margin-bottom:0;">
                    <i class="bi bi-people-fill" style="color:#7c3aed;"></i>
                </div>
                <span style="background:#f0fdf4;color:#16a34a;font-size:12px;font-weight:600;padding:3px 8px;border-radius:20px;">
                    +12%
                </span>
            </div>
            <div class="stat-value">@(ViewBag.TotalClienti ?? 0)</div>
            <div class="stat-label">Total clienți</div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px;">
                <div class="stat-icon" style="background:#fff7ed;margin-bottom:0;">
                    <i class="bi bi-wrench-adjustable" style="color:#ea580c;"></i>
                </div>
                <span style="background:#f0fdf4;color:#16a34a;font-size:12px;font-weight:600;padding:3px 8px;border-radius:20px;">
                    +9%
                </span>
            </div>
            <div class="stat-value">@(ViewBag.TotalProgramari ?? 0)</div>
            <div class="stat-label">Total programări</div>
        </div>
    </div>
</div>

<!-- Grafice principale -->
<div class="row g-4 mb-4">
    <!-- Grafic venituri lunare -->
    <div class="col-md-8">
        <div class="content-card h-100">
            <div class="content-card-header">
                <div>
                    <h5>Revenue vs Profit Trend</h5>
                    <p>Performanță financiară lunară — ultimele 6 luni</p>
                </div>
                @{
                    decimal venituriLunare = ViewBag.VenituriLuna ?? 0;
                    decimal mediaLunara = venituriLunare;
                }
                <div style="text-align:right;">
                    <div style="font-size:11px;color:var(--text-muted);">Avg. lunar</div>
                    <div style="font-size:15px;font-weight:700;color:#2563eb;">@mediaLunara.ToString("N0") lei</div>
                </div>
            </div>
            <div style="padding:20px;">
                <canvas id="chartVenituri" height="120"></canvas>
            </div>
        </div>
    </div>

    <!-- Grafic lucrări frecvente -->
    <div class="col-md-4">
        <div class="content-card h-100">
            <div class="content-card-header">
                <div>
                    <h5>Lucrări frecvente</h5>
                    <p>Top 5 servicii</p>
                </div>
            </div>
            <div style="padding:20px;">
                <canvas id="chartLucrari" height="220"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Tabele statistici -->
<div class="row g-4 mb-4">
    <!-- Top piese -->
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Top 5 piese utilizate</h5>
                    <p>După cantitate</p>
                </div>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Piesă</th>
                        <th>Cantitate</th>
                        <th>Valoare</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int i = 1;
                    }
                    @if (ViewBag.PieseTop != null)
                    {
                        @foreach (var piesa in ViewBag.PieseTop)
                        {
                            <tr>
                                <td>
                                    <span style="width:24px;height:24px;background:@(i == 1 ? "#fbbf24" : i == 2 ? "#94a3b8" : i == 3 ? "#cd7c2f" : "#e2e8f0");color:@(i <= 3 ? "white" : "var(--text-muted)");border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">
                                        @i
                                    </span>
                                </td>
                                <td style="font-size:13px;font-weight:500;">@piesa.Denumire</td>
                                <td style="font-size:13px;">@piesa.TotalCantitate buc.</td>
                                <td style="font-size:13px;font-weight:600;color:#2563eb;">@piesa.TotalValoare.ToString("N2") lei</td>
                            </tr>
                            i++;
                        }
                    }
                    @if (i == 1)
                    {
                        <tr><td colspan="4" style="text-align:center;color:var(--text-muted);padding:20px;">Nu există date.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Top clienți -->
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Top 5 clienți</h5>
                    <p>După număr de vizite</p>
                </div>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Client</th>
                        <th>Programări</th>
                        <th>Total cheltuit</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int j = 1;
                    }
                    @if (ViewBag.ClientiTop != null)
                    {
                        @foreach (var client in ViewBag.ClientiTop)
                        {
                            <tr>
                                <td>
                                    <span style="width:24px;height:24px;background:@(j == 1 ? "#fbbf24" : j == 2 ? "#94a3b8" : j == 3 ? "#cd7c2f" : "#e2e8f0");color:@(j <= 3 ? "white" : "var(--text-muted)");border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">
                                        @j
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:8px;">
                                        <div class="client-avatar" style="width:28px;height:28px;font-size:10px;">
                                            @(client.Nume.Length >= 2 ? client.Nume.Substring(0, 1) : "?")
                                        </div>
                                        <span style="font-size:13px;font-weight:500;">@client.Nume</span>
                                    </div>
                                </td>
                                <td style="font-size:13px;">@client.NrProgramari</td>
                                <td style="font-size:13px;font-weight:600;color:#16a34a;">@client.TotalCheltuit.ToString("N2") lei</td>
                            </tr>
                            j++;
                        }
                    }
                    @if (j == 1)
                    {
                        <tr><td colspan="4" style="text-align:center;color:var(--text-muted);padding:20px;">Nu există date.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Top lucrări -->
<div class="content-card mb-4">
    <div class="content-card-header">
        <div>
            <h5>Top 5 lucrări efectuate</h5>
            <p>Cele mai frecvente servicii</p>
        </div>
    </div>
    <table class="custom-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Lucrare</th>
                <th>Nr. execuții</th>
                <th>Total manoperă</th>
                <th>Frecvență</th>
            </tr>
        </thead>
        <tbody>
            @{
                int k = 1; int maxCount = 1;
            }
            @if (ViewBag.LucrariTop != null)
            {
                @foreach (var lucrare in ViewBag.LucrariTop)
                {
                    if (k == 1) maxCount = lucrare.Count;
                    <tr>
                        <td>
                            <span style="width:24px;height:24px;background:@(k == 1 ? "#fbbf24" : k == 2 ? "#94a3b8" : k == 3 ? "#cd7c2f" : "#e2e8f0");color:@(k <= 3 ? "white" : "var(--text-muted)");border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;">
                                @k
                            </span>
                        </td>
                        <td style="font-weight:500;">@lucrare.Denumire</td>
                        <td style="font-size:13px;">@lucrare.Count execuții</td>
                        <td style="font-size:13px;font-weight:600;color:#2563eb;">@lucrare.TotalManopera.ToString("N2") lei</td>
                        <td style="min-width:150px;">
                            @{
                                int proc = maxCount > 0 ? (int)((double)lucrare.Count / maxCount * 100) : 0;
                            }
                            <div style="display:flex;align-items:center;gap:8px;">
                                <div style="flex:1;background:#e2e8f0;border-radius:4px;height:6px;">
                                    <div style="width:@proc%;height:100%;background:#2563eb;border-radius:4px;"></div>
                                </div>
                                <span style="font-size:12px;color:var(--text-muted);min-width:30px;">@proc%</span>
                            </div>
                        </td>
                    </tr>
                    k++;
                }
            }
            @if (k == 1)
            {
                <tr><td colspan="5" style="text-align:center;color:var(--text-muted);padding:20px;">Nu există date.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- Grafic statusuri programări -->
<div class="row g-4">
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Distribuție programări</h5>
                    <p>După status</p>
                </div>
            </div>
            <div style="padding:20px;">
                <canvas id="chartStatusuri" height="200"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Situație facturi</h5>
                    <p>Încasate vs neîncasate</p>
                </div>
            </div>
            <div style="padding:20px;">
                <canvas id="chartFacturi" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const gridColor = 'rgba(0,0,0,0.05)';
        const textColor = '#64748b';

        // Grafic venituri lunare
        const labelsVenituri = @Html.Raw(ViewBag.ProfitLunarLabels ?? "[]");
        const dataVenituri = @Html.Raw(ViewBag.ProfitLunarDate ?? "[]");

        new Chart(document.getElementById('chartVenituri'), {
            type: 'line',
            data: {
                labels: labelsVenituri,
                datasets: [
                    {
                        label: 'Venituri',
                        data: dataVenituri,
                        borderColor: '#2563eb',
                        backgroundColor: 'rgba(37,99,235,0.08)',
                        borderWidth: 2.5,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#2563eb',
                        pointRadius: 4
                    },
                    {
                        label: 'Profit estimat',
                        data: dataVenituri.map(v => Math.round(v * 0.45)),
                        borderColor: '#16a34a',
                        backgroundColor: 'rgba(22,163,74,0.06)',
                        borderWidth: 2,
                        fill: true,
                        tension: 0.4,
                        pointBackgroundColor: '#16a34a',
                        pointRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { size: 12 }, padding: 16 }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: gridColor },
                        ticks: { color: textColor, callback: v => v + ' lei' }
                    },
                    x: { grid: { display: false }, ticks: { color: textColor } }
                }
            }
        });

        // Grafic lucrări frecvente
        const labelsLucrari = @Html.Raw(ViewBag.LucrariTopLabels ?? "[]");
        const dataLucrari = @Html.Raw(ViewBag.LucrariTopDate ?? "[]");

        new Chart(document.getElementById('chartLucrari'), {
            type: 'doughnut',
            data: {
                labels: labelsLucrari,
                datasets: [{
                    data: dataLucrari,
                    backgroundColor: ['#2563eb','#16a34a','#ea580c','#7c3aed','#94a3b8'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { size: 11 }, padding: 12 }
                    }
                },
                cutout: '65%'
            }
        });

        // Grafic statusuri programări
        new Chart(document.getElementById('chartStatusuri'), {
            type: 'doughnut',
            data: {
                labels: ['Programată', 'În lucru', 'Finalizată', 'Anulată'],
                datasets: [{
                    data: [
                        @(ViewBag.NrProgramata ?? 0),
                        @(ViewBag.NrInLucru ?? 0),
                        @(ViewBag.NrFinalizata ?? 0),
                        @(ViewBag.NrAnulata ?? 0)
                    ],
                    backgroundColor: ['#2563eb', '#ea580c', '#16a34a', '#ef4444'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { size: 12 }, padding: 16 }
                    }
                },
                cutout: '65%'
            }
        });

        // Grafic facturi
        new Chart(document.getElementById('chartFacturi'), {
            type: 'doughnut',
            data: {
                labels: ['Plătite', 'Neîncasate', 'Parțial'],
                datasets: [{
                    data: [
                        @(ViewBag.NrPlatite ?? 0),
                        @(ViewBag.NrNeplata ?? 0),
                        @(ViewBag.NrPartial ?? 0)
                    ],
                    backgroundColor: ['#16a34a', '#ef4444', '#ea580c'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: { color: textColor, font: { size: 12 }, padding: 16 }
                    }
                },
                cutout: '65%'
            }
        });
    </script>
}
