@model IEnumerable<ServiceAutoLicenta.Models.Entities.Factura>
@using ServiceAutoLicenta.Models.Entities
@{
    ViewData["Title"] = "Facturi";
}

<div class="page-header">
    <div>
        <h2>Invoices</h2>
        <p>Gestionează facturile emise</p>
    </div>
    <div style="text-align:right;">
        <div style="font-size:12px;color:var(--text-muted);">Total încasat</div>
        <div style="font-size:20px;font-weight:700;color:#16a34a;">@((ViewBag.TotalIncasat as decimal? ?? 0).ToString("N2")) lei</div>
    </div>
</div>

@if (TempData["Succes"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Eroare"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Eroare"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stat cards -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div style="display:flex;align-items:center;gap:16px;">
                <div class="stat-icon" style="background:#eff6ff;margin-bottom:0;">
                    <i class="bi bi-file-earmark-text-fill" style="color:#2563eb;"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size:22px;">@Model.Count()</div>
                    <div class="stat-label">Total facturi</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div style="display:flex;align-items:center;gap:16px;">
                <div class="stat-icon" style="background:#f0fdf4;margin-bottom:0;">
                    <i class="bi bi-check-circle-fill" style="color:#16a34a;"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size:22px;color:#16a34a;">@Model.Count(f => f.StatusPlata == StatusPlata.Platita)</div>
                    <div class="stat-label">Plătite</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div style="display:flex;align-items:center;gap:16px;">
                <div class="stat-icon" style="background:#fef2f2;margin-bottom:0;">
                    <i class="bi bi-clock-fill" style="color:#ef4444;"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size:22px;color:#ef4444;">@Model.Count(f => f.StatusPlata == StatusPlata.Neplata)</div>
                    <div class="stat-label">Neîncasate</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div style="display:flex;align-items:center;gap:16px;">
                <div class="stat-icon" style="background:#fff7ed;margin-bottom:0;">
                    <i class="bi bi-hourglass-split" style="color:#ea580c;"></i>
                </div>
                <div>
                    <div class="stat-value" style="font-size:22px;color:#ea580c;">@Model.Count(f => f.StatusPlata == StatusPlata.Partial)</div>
                    <div class="stat-label">Parțial plătite</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filtre + Căutare -->
<div style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;">
    <a asp-action="Index" class="btn-outline-custom @(string.IsNullOrEmpty(ViewBag.Status) ? "active-filter" : "")">
        Toate
    </a>
    <a asp-action="Index" asp-route-status="Platita" class="btn-outline-custom @(ViewBag.Status == "Platita" ? "active-filter" : "")">
        <span style="width:8px;height:8px;background:#16a34a;border-radius:50%;display:inline-block;margin-right:4px;"></span>
        Plătite
    </a>
    <a asp-action="Index" asp-route-status="Neplata" class="btn-outline-custom @(ViewBag.Status == "Neplata" ? "active-filter" : "")">
        <span style="width:8px;height:8px;background:#ef4444;border-radius:50%;display:inline-block;margin-right:4px;"></span>
        Neîncasate
    </a>
    <a asp-action="Index" asp-route-status="Partial" class="btn-outline-custom @(ViewBag.Status == "Partial" ? "active-filter" : "")">
        <span style="width:8px;height:8px;background:#ea580c;border-radius:50%;display:inline-block;margin-right:4px;"></span>
        Parțial
    </a>
</div>

<div class="content-card" style="margin-bottom:16px;">
    <div style="padding:14px 20px;">
        <form method="get" style="display:flex;gap:8px;align-items:center;">
            <input type="hidden" name="status" value="@ViewBag.Status" />
            <div style="position:relative;flex:1;max-width:360px;">
                <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:var(--text-muted);font-size:14px;"></i>
                <input type="text" name="cautare" value="@ViewBag.Cautare"
                       style="padding:8px 12px 8px 32px;border:1px solid var(--border-color);border-radius:8px;font-size:13px;width:100%;outline:none;"
                       placeholder="Caută după serie, client, mașină..." />
            </div>
            <button type="submit" class="btn-outline-custom">Caută</button>
            @if (!string.IsNullOrEmpty(ViewBag.Cautare))
            {
                <a asp-action="Index" asp-route-status="@ViewBag.Status" class="btn-outline-custom" style="color:#ef4444;border-color:#fca5a5;">
                    <i class="bi bi-x-lg"></i>
                </a>
            }
        </form>
    </div>
</div>

<!-- Tabel facturi -->
<div class="content-card">
    @if (!Model.Any())
    {
        <div style="text-align:center;padding:60px 20px;color:var(--text-muted);">
            <i class="bi bi-file-earmark-x" style="font-size:3rem;opacity:0.3;"></i>
            <p style="margin-top:12px;">Nu există facturi înregistrate.</p>
        </div>
    }
    else
    {
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Serie / Nr.</th>
                    <th>Client</th>
                    <th>Mașină</th>
                    <th>Data emitere</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Acțiuni</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td>
                            <span style="font-family:monospace;font-weight:600;background:#f1f5f9;padding:3px 8px;border-radius:4px;font-size:12px;">
                                @f.SerieNumar
                            </span>
                        </td>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;">
                                <div class="client-avatar" style="font-size:11px;">
                                    @(f.Programare.Masina.Client.Nume.Substring(0, 1))@(f.Programare.Masina.Client.Prenume.Substring(0, 1))
                                </div>
                                <span style="font-weight:500;font-size:14px;">@f.Programare.Masina.Client.NumeComplet</span>
                            </div>
                        </td>
                        <td style="font-size:13px;color:var(--text-muted);">@f.Programare.Masina.NrInmatriculare</td>
                        <td style="font-size:13px;color:var(--text-muted);">@f.DataEmitere.ToString("dd.MM.yyyy")</td>
                        <td style="font-weight:700;font-size:14px;">@f.Total.ToString("N2") lei</td>
                        <td>
                            <span class="badge-status @(f.StatusPlata == StatusPlata.Platita ? "badge-platita" :
                                                                                           f.StatusPlata == StatusPlata.Partial ? "badge-partial" : "badge-neplata")">
                        @f.StatusPlata
                    </span>
                </td>
                <td>
                    <div style="display:flex;gap:6px;">
                        <a asp-action="Detalii" asp-route-id="@f.Id"
                           class="btn-outline-custom" style="padding:5px 10px;">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Sterge" asp-route-id="@f.Id"
                           class="btn-outline-custom" style="padding:5px 10px;color:#ef4444;border-color:#fca5a5;">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
                        }
            </tbody>
        </table>
    }
</div>

<style>
    .active-filter {
        background: var(--blue) !important;
        color: white !important;
        border-color: var(--blue) !important;
    }
</style>
