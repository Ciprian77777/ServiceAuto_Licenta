@model IEnumerable<ServiceAutoLicenta.Models.Entities.Factura>
@using ServiceAutoLicenta.Models.Entities
@{
    ViewData["Title"]="Facturi";
}

<div class="page-header">
    <div>
        <h2>Facturi</h2>
        <p>Gestionează facturile emise</p>
    </div>
</div>

@if(TempData["Succes"]!=null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if(TempData["Eroare"]!=null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3">
        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Eroare"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="page-with-stats">
    <aside class="pstats">
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-file-earmark-text-fill"></i></div>
            <div class="stat-value">@Model.Count()</div>
            <div class="stat-label">Total facturi</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
            <div class="stat-value">@Model.Count(f=>f.StatusPlata==StatusPlata.Platita)</div>
            <div class="stat-label">Plătite</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-clock-fill"></i></div>
            <div class="stat-value">@Model.Count(f=>f.StatusPlata==StatusPlata.Neplata)</div>
            <div class="stat-label">Neîncasate</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-hourglass-split"></i></div>
            <div class="stat-value">@Model.Count(f=>f.StatusPlata==StatusPlata.Partial)</div>
            <div class="stat-label">Parțial plătite</div>
        </div>
        <div class="stat-card">
            <div class="stat-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="stat-value" style="font-size:22px;">@(((decimal)(ViewBag.TotalIncasat??0)).ToString("N0"))</div>
            <div class="stat-label">Total încasat (lei)</div>
        </div>
    </aside>

    <div class="pmain">
        <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;">
            <a asp-action="Index" class="btn-outline-custom @(string.IsNullOrEmpty(ViewBag.Status)?"active-filter":"")">Toate</a>
            <a asp-action="Index" asp-route-status="Platita" class="btn-outline-custom @(ViewBag.Status=="Platita"?"active-filter":"")">
                <span style="width:7px;height:7px;background:#15803d;display:inline-block;margin-right:4px;"></span>Plătite
            </a>
            <a asp-action="Index" asp-route-status="Neplata" class="btn-outline-custom @(ViewBag.Status=="Neplata"?"active-filter":"")">
                <span style="width:7px;height:7px;background:#b91c1c;display:inline-block;margin-right:4px;"></span>Neîncasate
            </a>
            <a asp-action="Index" asp-route-status="Partial" class="btn-outline-custom @(ViewBag.Status=="Partial"?"active-filter":"")">
                <span style="width:7px;height:7px;background:#c2410c;display:inline-block;margin-right:4px;"></span>Parțial
            </a>
        </div>

        <div class="content-card" style="margin-bottom:12px;">
            <div style="padding:12px 18px;">
                <form method="get" style="display:flex;gap:8px;align-items:center;">
                    <input type="hidden" name="status" value="@ViewBag.Status" />
                    <div style="position:relative;flex:1;max-width:360px;">
                        <i class="bi bi-search" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);color:#aaa;font-size:13px;"></i>
                        <input type="text" name="cautare" value="@ViewBag.Cautare" class="form-control"
                               style="padding-left:32px;" placeholder="Caută după serie, client, mașină..." />
                    </div>
                    <button type="submit" class="btn-outline-custom">Caută</button>
                    @if(!string.IsNullOrEmpty(ViewBag.Cautare))
                    {
                        <a asp-action="Index" asp-route-status="@ViewBag.Status" class="btn-outline-custom" style="color:#b91c1c;border-color:#fca5a5;"><i class="bi bi-x-lg"></i></a>
                    }
                </form>
            </div>
        </div>

        <div class="content-card">
            @if(!Model.Any())
            {
                <div style="text-align:center;padding:50px 20px;color:#aaa;">
                    <i class="bi bi-file-earmark-x" style="font-size:2.5rem;opacity:0.3;"></i>
                    <p style="margin-top:12px;">Nu există facturi înregistrate.</p>
                </div>
            }
            else
            {
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Serie / Nr.</th>
                            <th>Client</th>
                            <th>Mașină</th>
                            <th>Data emitere</th>
                            <th>Total</th>
                            <th>Status</th>
                            <th>Acțiuni</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach(var f in Model)
                        {
                            <tr>
                                <td>
                                    <span style="font-family:monospace;font-weight:600;font-size:13px;color:#e0e0e0;">@f.SerieNumar</span>
                                </td>
                                <td>
                                    <div style="display:flex;align-items:center;gap:9px;">
                                        <div class="client-avatar">
                                            @(f.Programare.Masina.Client.Nume[0])@(f.Programare.Masina.Client.Prenume[0])
                                        </div>
                                        <span style="font-weight:600;font-size:13px;">@f.Programare.Masina.Client.NumeComplet</span>
                                    </div>
                                </td>
                                <td style="font-size:12px;color:#888;">@f.Programare.Masina.NrInmatriculare</td>
                                <td style="font-size:12px;color:#888;">@f.DataEmitere.ToString("dd.MM.yyyy")</td>
                                <td style="font-weight:700;font-size:13px;">@f.Total.ToString("N2") lei</td>
                                <td>
                                    <span class="badge-status @(f.StatusPlata==StatusPlata.Platita?"badge-platita":f.StatusPlata==StatusPlata.Partial?"badge-partial":"badge-neplata")">
                                        @f.StatusPlata
                                    </span>
                                </td>
                                <td>
                                    <div style="display:flex;gap:5px;">
                                        <a asp-action="Detalii" asp-route-id="@f.Id" class="btn-outline-custom" style="padding:4px 9px;"><i class="bi bi-eye"></i></a>
                                        <a asp-action="Sterge" asp-route-id="@f.Id" class="btn-outline-custom" style="padding:4px 9px;color:#b91c1c;border-color:#fca5a5;"><i class="bi bi-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<style>
    .active-filter { background:var(--red)!important;color:#fff!important;border-color:var(--red)!important; }
</style>
