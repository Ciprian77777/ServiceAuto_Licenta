@model ServiceAutoLicenta.Models.Entities.Factura
@using ServiceAutoLicenta.Models.Entities
@{
    ViewData["Title"]="Factură " + Model.SerieNumar;
}

<div class="page-header">
    <div style="display:flex;align-items:center;gap:12px;">
        <a asp-action="Index" class="btn-outline-custom" style="padding:8px 12px;">
            <i class="bi bi-arrow-left"></i>
        </a>
        <a asp-action="Print" asp-route-id="@Model.Id"
           target="_blank" class="btn-outline-custom">
            <i class="bi bi-printer"></i> Printeaza
        </a>
        <div>
            <h2 style="font-family:monospace;">@Model.SerieNumar</h2>
            <p>Emisă pe @Model.DataEmitere.ToString("dd MMMM yyyy")</p>
        </div>
    </div>
    <span class="badge-status @(Model.StatusPlata==StatusPlata.Platita? "badge-platita" :
                                           Model.StatusPlata==StatusPlata.Partial? "badge-partial" : "badge-neplata")"
          style="font-size:14px;padding:8px 16px;">
        @Model.StatusPlata
    </span>
</div>

@if(TempData["Succes"]!=null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="bi bi-check-circle me-2"></i>@TempData["Succes"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-4">
        <div class="content-card mb-4">
            <div class="content-card-header"><h5>Date factură</h5></div>
            <div style="padding:20px;display:flex;flex-direction:column;gap:12px;">
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Serie/Nr.</span>
                    <span style="font-family:monospace;font-weight:600;">@Model.SerieNumar</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Data emitere</span>
                    <span>@Model.DataEmitere.ToString("dd.MM.yyyy")</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Scadență</span>
                    <span>@(Model.DataScadenta?.ToString("dd.MM.yyyy")??"-")</span>
                </div>
                <div style="display:flex;justify-content:space-between;font-size:14px;">
                    <span style="color:var(--text-muted);">Metodă plată</span>
                    <span>@(Model.MetodaPlata?.ToString()??"-")</span>
                </div>
            </div>
        </div>

        <div class="content-card mb-4">
            <div class="content-card-header"><h5>Client</h5></div>
            <div style="padding:20px;">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;">
                    <div class="client-avatar" style="width:44px;height:44px;font-size:15px;">
                        @(Model.Programare.Masina.Client.Nume.Substring(0, 1))@(Model.Programare.Masina.Client.Prenume.Substring(0, 1))
                    </div>
                    <div>
                        <div style="font-weight:600;">@Model.Programare.Masina.Client.NumeComplet</div>
                        <div style="font-size:13px;color:var(--text-muted);">@Model.Programare.Masina.Client.Telefon</div>
                    </div>
                </div>
                <div style="font-size:13px;color:var(--text-muted);display:flex;align-items:center;gap:6px;">
                    <i class="bi bi-car-front"></i>
                    @Model.Programare.Masina.NrInmatriculare — @Model.Programare.Masina.Marca @Model.Programare.Masina.ModelMasina
                </div>
            </div>
        </div>

        @if(Model.StatusPlata!=StatusPlata.Platita)
        {
            <div class="content-card" style="border:1.5px solid #86efac;">
                <div class="content-card-header" style="background:rgba(22,163,74,0.15);">
                    <h5 style="color:#86efac;"><i class="bi bi-cash me-2"></i>Înregistrează plata</h5>
                </div>
                <div style="padding:16px;">
                    <form asp-action="ActualizeazaStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div style="margin-bottom:10px;">
                            <select name="statusPlata" class="form-select"
                                    asp-items="Html.GetEnumSelectList<ServiceAutoLicenta.Models.Entities.StatusPlata>()">
                            </select>
                        </div>
                        <div style="margin-bottom:12px;">
                            <select name="metodaPlata" class="form-select"
                                    asp-items="Html.GetEnumSelectList<ServiceAutoLicenta.Models.Entities.MetodaPlata>()">
                                <option value="">-- Metodă plată --</option>
                            </select>
                        </div>
                        <button type="submit" class="btn-primary-custom" style="width:100%;justify-content:center;background:#16a34a;">
                            <i class="bi bi-check-lg"></i> Salvează plata
                        </button>
                    </form>
                    @if(Model.StatusPlata==StatusPlata.Neplata)
                    {
                        <a asp-action="PlataCard" asp-route-id="@Model.Id"
                           class="btn-outline-custom" style="width:100%;justify-content:center;margin-top:8px;">
                            <i class="bi bi-credit-card me-1"></i> Plătește cu card
                        </a>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-md-8">
        <div class="content-card">
            <div class="content-card-header">
                <div>
                    <h5>Detalii lucrări</h5>
                    <p>Servicii prestate</p>
                </div>
            </div>
            <table class="custom-table">
                <thead>
                    <tr>
                        <th>Descriere</th>
                        <th style="text-align:right;">Preț</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach(var lucrare in Model.Programare.Lucrari)
                    {
                        <tr style="background:rgba(0,0,0,0.1);">
                            <td>
                                <div style="display:flex;align-items:center;gap:8px;">
                                    <div style="width:28px;height:28px;background:rgba(37,99,235,0.25);border-radius:6px;display:flex;align-items:center;justify-content:center;">
                                        <i class="bi bi-wrench" style="color:#2563eb;font-size:12px;"></i>
                                    </div>
                                    <strong>@lucrare.Denumire</strong>
                                </div>
                            </td>
                            <td style="text-align:right;font-weight:600;">@lucrare.Manopera.ToString("N2") lei</td>
                        </tr>
                        @foreach(var lp in lucrare.LucrarePiese)
                        {
                            <tr>
                                <td style="padding-left:48px;font-size:13px;color:var(--text-muted);">
                                    @lp.Piesa.Denumire
                                    <span style="background:rgba(255,255,255,0.12);padding:1px 6px;border-radius:4px;font-size:11px;margin-left:4px;">× @lp.Cantitate</span>
                                </td>
                                <td style="text-align:right;font-size:13px;">@lp.Subtotal.ToString("N2") lei</td>
                            </tr>
                        }
                    }
                </tbody>
                <tfoot>
                    <tr style="background:rgba(0,0,0,0.1);">
                        <td style="text-align:right;color:var(--text-muted);font-size:13px;">Subtotal (fără TVA)</td>
                        <td style="text-align:right;font-size:13px;">@Model.Subtotal.ToString("N2") lei</td>
                    </tr>
                    <tr style="background:rgba(0,0,0,0.1);">
                        <td style="text-align:right;color:var(--text-muted);font-size:13px;">TVA (19%)</td>
                        <td style="text-align:right;font-size:13px;">@Model.TvaValoare.ToString("N2") lei</td>
                    </tr>
                    <tr>
                        <td style="text-align:right;font-size:18px;font-weight:700;">TOTAL</td>
                        <td style="text-align:right;font-size:18px;font-weight:700;color:#2563eb;">@Model.Total.ToString("N2") lei</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>