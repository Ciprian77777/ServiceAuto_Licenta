@model ServiceAutoLicenta.Models.Entities.Factura
@{
    ViewData["Title"] = "Plata cu card";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Detalii" asp-route-id="@Model.Id" class="btn btn-outline-secondary me-3">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h2 class="mb-0">Plata cu card</h2>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">

        <!-- Sumar factură -->
        <div class="card shadow-sm mb-4">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <p class="mb-0 text-muted small">Factura</p>
                    <strong>@Model.SerieNumar</strong>
                    <span class="text-muted ms-2">— @Model.Programare.Masina.Client.NumeComplet</span>
                </div>
                <div class="text-end">
                    <p class="mb-0 text-muted small">Total de plata</p>
                    <strong class="fs-4 text-primary">@Model.Total.ToString("N2") lei</strong>
                </div>
            </div>
        </div>

        @* 
        <!-- Card preview vizual -->
        <div id="card-preview" class="mb-4 p-4 rounded-4 text-white"
             style="background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
                    min-height: 180px; position: relative; overflow: hidden;">
            <div style="position:absolute;top:-30px;right:-30px;width:150px;height:150px;
                        border-radius:50%;background:rgba(255,255,255,0.05);"></div>
            <div style="position:absolute;bottom:-40px;right:40px;width:100px;height:100px;
                        border-radius:50%;background:rgba(255,255,255,0.05);"></div>

            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <i class="bi bi-wifi" style="font-size:1.5rem;opacity:0.7;transform:rotate(90deg);display:inline-block;"></i>
                </div>
                <div class="text-end">
                    <span id="card-type-label" style="font-size:1.8rem;opacity:0.9;">💳</span>
                </div>
            </div>

            <div id="card-number-display" class="mb-3"
                 style="font-family: monospace; font-size: 1.2rem; letter-spacing: 3px; opacity: 0.9;">
                •••• •••• •••• ••••
            </div>

            <div class="d-flex justify-content-between align-items-end">
                <div>
                    <p class="mb-0" style="font-size:0.65rem;opacity:0.6;text-transform:uppercase;">Titular</p>
                    <p id="card-name-display" class="mb-0" style="font-size:0.9rem;text-transform:uppercase;">
                        NUME TITULAR
                    </p>
                </div>
                <div>
                    <p class="mb-0" style="font-size:0.65rem;opacity:0.6;text-transform:uppercase;">Expiră</p>
                    <p id="card-exp-display" class="mb-0" style="font-size:0.9rem;">MM/AA</p>
                </div>
            </div>
        </div> *@

        <!-- Formular plată -->
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="PlataCard" asp-controller="Facturi" method="post" id="payment-form">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <div class="mb-3">
                        <label class="form-label">Număr card</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-credit-card"></i></span>
                            <input type="text" name="numarCard" id="numarCard" class="form-control"
                                   placeholder="0000 0000 0000 0000" maxlength="19" required
                                   autocomplete="cc-number" />
                        </div>
                        <div class="invalid-feedback">Introduceți un numar de card valid.</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Titular card</label>
                        <input type="text" name="titular" id="titular" class="form-control"
                               placeholder="Nume Prenume" required autocomplete="cc-name" />
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-7">
                            <label class="form-label">Data expirare</label>
                            <input type="text" name="expirare" id="expirare" class="form-control"
                                   placeholder="MM/AA" maxlength="5" required autocomplete="cc-exp" />
                        </div>
                        <div class="col-5">
                            <label class="form-label">CVV</label>
                            <div class="input-group">
                                <input type="password" name="cvv" id="cvv" class="form-control"
                                       placeholder="•••" maxlength="4" required autocomplete="cc-csc" />
                                <span class="input-group-text" data-bs-toggle="tooltip"
                                      title="3 cifre pe spatele cardului">
                                    <i class="bi bi-question-circle"></i>
                                </span>
                            </div>
                        </div>
                    </div>

                    @* <!-- Securitate -->
                    <div class="d-flex align-items-center gap-2 mb-4 p-3 rounded"
                         style="background:var(--bs-success-bg-subtle)">
                        <i class="bi bi-shield-lock-fill text-success fs-5"></i>
                        <div>
                            <p class="mb-0 small text-success fw-bold">Plată securizată (simulare)</p>
                            <p class="mb-0 small text-muted">Datele cardului nu sunt stocate</p>
                        </div>
                        <div class="ms-auto d-flex gap-2 opacity-75">
                            <span class="badge bg-dark">VISA</span>
                            <span class="badge bg-danger">MC</span>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2" id="pay-btn">
                        <i class="bi bi-lock-fill me-2"></i>
                        Plătește @Model.Total.ToString("N2") lei
                    </button>*@
                </form> 

                <!-- Overlay procesare -->
                <div id="processing-overlay" class="d-none text-center py-4">
                    <div class="spinner-border text-primary mb-3" role="status"></div>
                    <p class="mb-0">Se proceseaza plata...</p>
                    <p class="text-muted small">Va rugam nu inchideti pagina</p>
                </div>
            </div>
        </div>

        @* <p class="text-center text-muted small mt-3">
            <i class="bi bi-info-circle me-1"></i>
            Aceasta este o simulare. Nicio sumă reală nu va fi debitată.
        </p> *@
    </div>
</div>

@section Scripts {
    <script>
        // Format număr card
        document.getElementById('numarCard').addEventListener('input', function (e) {
            let val = e.target.value.replace(/\D/g, '').substring(0, 16);
            let formatted = val.replace(/(\d{4})/g, '$1 ').trim();
            e.target.value = formatted;

            // Update preview
            let display = val.padEnd(16, '•');
            document.getElementById('card-number-display').textContent =
                display.substring(0,4) + ' ' + display.substring(4,8) + ' ' +
                display.substring(8,12) + ' ' + display.substring(12,16);

            // Detectează tipul cardului
            let type = '💳';
            if (val.startsWith('4')) type = 'VISA';
            else if (val.startsWith('5')) type = 'MC';
            else if (val.startsWith('3')) type = 'AMEX';
            document.getElementById('card-type-label').textContent = type;
        });

        // Format titular
        document.getElementById('titular').addEventListener('input', function (e) {
            let val = e.target.value.toUpperCase();
            document.getElementById('card-name-display').textContent = val || 'NUME TITULAR';
        });

        // Format expirare
        document.getElementById('expirare').addEventListener('input', function (e) {
            let val = e.target.value.replace(/\D/g, '').substring(0, 4);
            if (val.length >= 2) val = val.substring(0, 2) + '/' + val.substring(2);
            e.target.value = val;
            document.getElementById('card-exp-display').textContent = val || 'MM/AA';
        });

        // Submit cu overlay procesare
        document.getElementById('payment-form').addEventListener('submit', function (e) {
            let numar = document.getElementById('numarCard').value.replace(/\s/g, '');
            let exp = document.getElementById('expirare').value;
            let cvv = document.getElementById('cvv').value;

            if (numar.length < 16 || exp.length < 5 || cvv.length < 3) {
                e.preventDefault();
                alert('Va rugam completati toate campurile corect.');
                return;
            }

            document.getElementById('payment-form').classList.add('d-none');
            document.getElementById('processing-overlay').classList.remove('d-none');
        });

        // Tooltip Bootstrap
        var tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
        tooltipEls.forEach(el => new bootstrap.Tooltip(el));
    </script>
}
